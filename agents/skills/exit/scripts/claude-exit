#!/usr/bin/env bash
set -euo pipefail

ancestorScanStartProcessId="${CLAUDE_EXIT_ANCESTOR_SCAN_START_PROCESS_ID:-$PPID}"

if ! claudeProcessId=$(find-claude-ancestor-pid "$ancestorScanStartProcessId"); then
	echo "Safety check FAILED: no 'claude' process found among the ancestors of PID $ancestorScanStartProcessId"
	echo "Use /exit or Ctrl+D instead."
	exit 1
fi

echo "Claude PID: $claudeProcessId"

if [[ "${1:-}" == "--print-target" ]]; then
	exit 0
fi

echo "Sending SIGTERM for clean shutdown..."
kill -TERM "$claudeProcessId"
sleep 0.5
pkill -TERM -P "$claudeProcessId" 2>/dev/null || true
sleep 0.5
pkill -KILL -P "$claudeProcessId" 2>/dev/null || true
