#!/usr/bin/env bash
set -euo pipefail

DEFAULT_RESTART_HEADS_UP="claude-restart succeeded: this session was terminated and resumed. Continue from where you left off."
CONTINUATION_PROMPT="${1:-$DEFAULT_RESTART_HEADS_UP}"

ANCESTOR_SCAN_START_PROCESS_ID="${CLAUDE_RESTART_ANCESTOR_SCAN_START_PROCESS_ID:-$PPID}"

if ! CLAUDE_PID=$(find-claude-ancestor-pid "$ANCESTOR_SCAN_START_PROCESS_ID"); then
	echo "Safety check FAILED: no 'claude' process found among the ancestors of PID $ANCESTOR_SCAN_START_PROCESS_ID"
	echo "Use /exit or Ctrl+D instead."
	exit 1
fi

CLAUDE_CMDLINE=$(ps -ww -p "$CLAUDE_PID" -o args= 2>/dev/null || echo "")
EXTRACTED_SESSION_ID=""
if [[ "$CLAUDE_CMDLINE" =~ --resume[[:space:]]+([a-f0-9-]+) ]]; then
	EXTRACTED_SESSION_ID="${BASH_REMATCH[1]}"
elif [[ "$CLAUDE_CMDLINE" =~ --session-id[[:space:]]+([a-f0-9-]+) ]]; then
	EXTRACTED_SESSION_ID="${BASH_REMATCH[1]}"
fi

if [[ -z "$EXTRACTED_SESSION_ID" ]]; then
	WORKING_DIRECTORY=$(pwd)
	WORKING_DIRECTORY_SLASHES_REPLACED="${WORKING_DIRECTORY//\//-}"
	CLAUDE_PROJECT_DIR_NAME="${WORKING_DIRECTORY_SLASHES_REPLACED//./-}"
	CLAUDE_SESSIONS_DIR="$HOME/.claude/projects/$CLAUDE_PROJECT_DIR_NAME"
	MOST_RECENT_SESSION_FILE=""
	MOST_RECENT_MODIFICATION_TIME=0
	for SESSION_CANDIDATE in "$CLAUDE_SESSIONS_DIR"/*.jsonl; do
		[[ -f "$SESSION_CANDIDATE" ]] || continue
		CANDIDATE_MODIFICATION_TIME=$(stat -f %m "$SESSION_CANDIDATE" 2>/dev/null || stat -c %Y "$SESSION_CANDIDATE" 2>/dev/null || echo 0)
		if ((CANDIDATE_MODIFICATION_TIME > MOST_RECENT_MODIFICATION_TIME)); then
			MOST_RECENT_MODIFICATION_TIME=$CANDIDATE_MODIFICATION_TIME
			MOST_RECENT_SESSION_FILE=$SESSION_CANDIDATE
		fi
	done
	if [[ -n "$MOST_RECENT_SESSION_FILE" ]]; then
		MOST_RECENT_SESSION_BASENAME="${MOST_RECENT_SESSION_FILE##*/}"
		EXTRACTED_SESSION_ID="${MOST_RECENT_SESSION_BASENAME%.jsonl}"
	fi
fi

if [[ -n "$EXTRACTED_SESSION_ID" ]]; then
	RESUME_COMMAND="claude --resume $EXTRACTED_SESSION_ID"
else
	RESUME_COMMAND="claude --continue"
fi

echo "Restarting with: $RESUME_COMMAND"

if [[ -n "${HERDR_PANE_ID:-}" ]]; then
	CURRENT_HERDR_PANE="$HERDR_PANE_ID"

	nohup bash -c "
	    while kill -0 $CLAUDE_PID 2>/dev/null; do
	        herdr pane get '$CURRENT_HERDR_PANE' >/dev/null 2>&1 || exit 0
	        sleep 0.2
	    done

	    pkill -TERM -P $CLAUDE_PID 2>/dev/null || true
	    sleep 0.5
	    pkill -KILL -P $CLAUDE_PID 2>/dev/null || true

	    herdr pane get '$CURRENT_HERDR_PANE' >/dev/null 2>&1 || exit 0

	    sleep 1
	    herdr pane run '$CURRENT_HERDR_PANE' '$RESUME_COMMAND'

	    if [[ -n '$CONTINUATION_PROMPT' ]]; then
	        herdr wait output '$CURRENT_HERDR_PANE' --match '❯' --timeout 60000 >/dev/null 2>&1 || true
	        sleep 2
	        herdr pane send-text '$CURRENT_HERDR_PANE' '$CONTINUATION_PROMPT'
	        sleep 0.5
	        herdr pane send-keys '$CURRENT_HERDR_PANE' Enter
	    fi
	" &>/dev/null &
	disown
elif [[ -n "${TMUX:-}" ]]; then
	CURRENT_TMUX_PANE="$TMUX_PANE"

	nohup bash -c "
	    while kill -0 $CLAUDE_PID 2>/dev/null; do
	        tmux display-message -t '$CURRENT_TMUX_PANE' -p '' 2>/dev/null || exit 0
	        sleep 0.2
	    done

	    pkill -TERM -P $CLAUDE_PID 2>/dev/null || true
	    sleep 0.5
	    pkill -KILL -P $CLAUDE_PID 2>/dev/null || true

	    tmux display-message -t '$CURRENT_TMUX_PANE' -p '' 2>/dev/null || exit 0

	    sleep 1
	    tmux send-keys -t '$CURRENT_TMUX_PANE' '$RESUME_COMMAND' Enter

	    if [[ -n '$CONTINUATION_PROMPT' ]]; then
	        for ATTEMPT in \$(seq 1 60); do
	            tmux display-message -t '$CURRENT_TMUX_PANE' -p '' 2>/dev/null || exit 0
	            PANE_CONTENT=\$(tmux capture-pane -t '$CURRENT_TMUX_PANE' -p -S -5)
	            if echo \"\$PANE_CONTENT\" | grep -q '❯'; then
	                break
	            fi
	            sleep 1
	        done
	        sleep 2
	        tmux display-message -t '$CURRENT_TMUX_PANE' -p '' 2>/dev/null || exit 0

	        CONTINUATION_PROMPT_BUFFER_FILE=\$(mktemp -t claude-restart-continuation.XXXXXX)
	        printf '%s' '$CONTINUATION_PROMPT' > \"\$CONTINUATION_PROMPT_BUFFER_FILE\"
	        tmux load-buffer -b claude-restart-continuation \"\$CONTINUATION_PROMPT_BUFFER_FILE\"
	        tmux paste-buffer -b claude-restart-continuation -t '$CURRENT_TMUX_PANE'
	        rm -f \"\$CONTINUATION_PROMPT_BUFFER_FILE\"
	        tmux delete-buffer -b claude-restart-continuation 2>/dev/null || true
	        sleep 0.5
	        tmux send-keys -t '$CURRENT_TMUX_PANE' Enter
	    fi
	" &>/dev/null &
	disown
else
	echo "Not inside herdr or tmux, cannot auto-restart."
	echo "Use /exit then manually: claude --continue"
	exit 1
fi

kill -TERM "$CLAUDE_PID"
