#!/usr/bin/env bash

set -Eeuo pipefail

readonly DEFAULT_GENERATIONS_TO_KEEP=5
readonly NIX_DAEMON_PROFILE="/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"

main() {
	_ensure_nix_in_path_or_source_daemon_profile || {
		echo "Error: nix is not available in PATH and nix-daemon profile was not found." >&2
		exit 1
	}

	local scope="user"
	local generations_to_keep="$DEFAULT_GENERATIONS_TO_KEEP"
	local dry_run=false

	while [[ $# -gt 0 ]]; do
		case $1 in
		-a | --all)
			scope="all"
			shift
			;;
		-u | --user)
			scope="user"
			shift
			;;
		-s | --system)
			scope="system"
			shift
			;;
		-k | --keep)
			generations_to_keep="$2"
			shift 2
			;;
		-d | --dry-run)
			dry_run=true
			shift
			;;
		-h | --help)
			_print_usage
			exit 0
			;;
		*)
			echo "Unknown option: $1" >&2
			_print_usage
			exit 1
			;;
		esac
	done

	echo "=== Nix Garbage Collection ==="
	echo ""

	case $scope in
	user)
		_clean_home_manager_generations "$generations_to_keep" "$dry_run"
		_collect_user_garbage "$dry_run"
		;;
	system)
		_collect_system_garbage "$dry_run"
		;;
	all)
		_clean_home_manager_generations "$generations_to_keep" "$dry_run"
		_collect_user_garbage "$dry_run"
		_collect_system_garbage "$dry_run"
		;;
	esac

	if [ "$dry_run" = true ]; then
		echo "=== Dry run complete (no changes made) ==="
	else
		echo "=== Garbage collection complete ==="
	fi
}

_print_usage() {
	cat <<EOF
Usage: nix-gc [OPTIONS]

Clean up old Nix generations and run garbage collection.

Options:
    -a, --all       Clean both user and system store (requires sudo for system)
    -u, --user      Clean user generations and garbage only (default)
    -s, --system    Clean system store only (requires sudo)
    -k, --keep N    Keep N generations (default: $DEFAULT_GENERATIONS_TO_KEEP)
    -d, --dry-run   Show what would be deleted without deleting
    -h, --help      Show this help message

Examples:
    nix-gc              # Clean user generations keeping 5, run user gc
    nix-gc -a           # Clean user + system store
    nix-gc -k 3         # Keep only 3 generations
    nix-gc -d           # Dry run to see what would be deleted
EOF
}

_ensure_nix_in_path_or_source_daemon_profile() {
	if command -v nix-collect-garbage >/dev/null 2>&1; then
		return 0
	fi

	if [ -f "$NIX_DAEMON_PROFILE" ]; then
		# shellcheck disable=SC1090
		. "$NIX_DAEMON_PROFILE"
	fi

	command -v nix-collect-garbage >/dev/null 2>&1
}

_resolve_nix_collect_garbage_path() {
	command -v nix-collect-garbage
}

_clean_home_manager_generations() {
	local generations_to_keep=$1
	local dry_run=$2

	echo ">> Cleaning home-manager generations (keeping $generations_to_keep)..."

	if ! command -v home-manager &>/dev/null; then
		echo "   home-manager not found, skipping generation cleanup"
		echo ""
		return
	fi

	local all_generation_ids
	mapfile -t all_generation_ids < <(home-manager generations | grep -oP '(?<=: id )\d+')

	local total_generations=${#all_generation_ids[@]}
	local count_to_remove=$((total_generations - generations_to_keep))

	local generations_to_remove=()
	if [ "$count_to_remove" -gt 0 ]; then
		generations_to_remove=("${all_generation_ids[@]:0:$count_to_remove}")
	fi

	if [ ${#generations_to_remove[@]} -eq 0 ]; then
		echo "   No old generations to remove"
		echo ""
		return
	fi

	echo "   Found ${#generations_to_remove[@]} old generation(s) to remove"

	if [ "$dry_run" = true ]; then
		echo "   [DRY RUN] Would remove generations:"
		for generation_id in "${generations_to_remove[@]}"; do
			echo "     - $generation_id"
		done
	else
		for generation_id in "${generations_to_remove[@]}"; do
			echo "   Removing: $generation_id"
			home-manager remove-generations "$generation_id" 2>/dev/null || true
		done
	fi
	echo ""
}

_collect_user_garbage() {
	local dry_run=$1

	echo ">> Running user garbage collection..."

	local nix_collect_garbage_path
	nix_collect_garbage_path="$(_resolve_nix_collect_garbage_path)" || return 1

	if [ "$dry_run" = true ]; then
		local dead_paths_count
		dead_paths_count="$(nix-store --gc --print-dead 2>/dev/null | wc -l)"
		echo "   [DRY RUN] $dead_paths_count dead store paths would be removed"
	else
		"$nix_collect_garbage_path"
	fi
	echo ""
}

_collect_system_garbage() {
	local dry_run=$1

	echo ">> Running system garbage collection (requires sudo)..."

	local nix_collect_garbage_path
	nix_collect_garbage_path="$(_resolve_nix_collect_garbage_path)" || return 1

	if [ "$dry_run" = true ]; then
		echo "   [DRY RUN] Would run: sudo $nix_collect_garbage_path -d"
	else
		sudo "$nix_collect_garbage_path" -d
	fi
	echo ""
}

main "$@"
