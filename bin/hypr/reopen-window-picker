#!/usr/bin/env bash
set -Eeuo pipefail

readonly CLOSED_WINDOWS_HISTORY_FILE="${XDG_RUNTIME_DIR:-/tmp}/hypr-closed-windows-history"

main() {
	[[ ! -s "$CLOSED_WINDOWS_HISTORY_FILE" ]] && exit 0

	local display_lines=()
	local json_lines=()

	_load_history_entries

	local fuzzel_input=""
	for ((i = ${#display_lines[@]} - 1; i >= 0; i--)); do
		fuzzel_input+="${display_lines[$i]}"$'\n'
	done

	local selected_display
	selected_display=$(echo -n "$fuzzel_input" | hypr-fuzzel --dmenu --prompt "Reopen: ")
	[[ -z "$selected_display" ]] && exit 0

	_reopen_selected_window "$selected_display"
}

_load_history_entries() {
	while IFS= read -r line; do
		local entry_title entry_workspace_id
		entry_title=$(echo "$line" | jq -r '.title')
		entry_workspace_id=$(echo "$line" | jq -r '.workspace')
		display_lines+=("[$entry_workspace_id] $entry_title")
		json_lines+=("$line")
	done <"$CLOSED_WINDOWS_HISTORY_FILE"
}

_reopen_selected_window() {
	local selected_display=$1
	local launch_command="" target_workspace_id="" selected_line_number=""

	for ((i = ${#display_lines[@]} - 1; i >= 0; i--)); do
		if [[ "${display_lines[$i]}" == "$selected_display" ]]; then
			launch_command=$(echo "${json_lines[$i]}" | jq -r '.cmd')
			target_workspace_id=$(echo "${json_lines[$i]}" | jq -r '.workspace')
			selected_line_number=$((i + 1))
			break
		fi
	done

	[[ -z "$launch_command" || "$launch_command" == "null" ]] && exit 1

	sed -i "${selected_line_number}d" "$CLOSED_WINDOWS_HISTORY_FILE"

	hyprctl dispatch exec "[workspace $target_workspace_id silent] $launch_command"
}

main
