#!/usr/bin/env bash

set -Eeuo pipefail

readonly ATK_VENDOR_ID="373b"
readonly ATK_HID_REPORT_ID="08"
readonly ATK_CMD_GET_EEPROM="08"
readonly ATK_CMD_SET_EEPROM="07"
readonly RATE_8K_HI="40"
readonly RATE_8K_LO="15"
readonly RATE_4K_HI="20"
readonly RATE_4K_LO="35"
readonly RATE_2K_HI="10"
readonly RATE_2K_LO="45"
readonly RATE_1K_HI="01"
readonly RATE_1K_LO="54"

main() {
	case "${1:-}" in
	get) _get_current_rate ;;
	set) _set_rate "${2:-}" ;;
	info) _show_device_info ;;
	*)
		echo "Usage: mouse-poll-rate <get|set|info>" >&2
		echo "  get          Show current polling rate" >&2
		echo "  set <rate>   Set rate (1k, 2k, 4k, 8k)" >&2
		echo "  info         Show device and USB info" >&2
		exit 1
		;;
	esac
}

_find_atk_hidraw_config_interface() {
	local hidraw_device
	for hidraw_sysfs in /sys/class/hidraw/hidraw*; do
		local vendor product interface_number
		vendor=$(cat "$hidraw_sysfs/device/../../idVendor" 2>/dev/null) || continue
		product=$(cat "$hidraw_sysfs/device/../../idProduct" 2>/dev/null) || continue
		interface_number=$(cat "$hidraw_sysfs/device/../bInterfaceNumber" 2>/dev/null) || continue

		if [[ "$vendor" == "$ATK_VENDOR_ID" && "$interface_number" == "01" ]]; then
			hidraw_device="/dev/$(basename "$hidraw_sysfs")"
			echo "$hidraw_device"
			return 0
		fi
	done

	echo "No ATK mouse found (vendor $ATK_VENDOR_ID, interface 1)" >&2
	return 1
}

_find_atk_usb_device_path() {
	for usb_device in /sys/bus/usb/devices/*; do
		local vendor
		vendor=$(cat "$usb_device/idVendor" 2>/dev/null) || continue
		if [[ "$vendor" == "$ATK_VENDOR_ID" ]]; then
			echo "$usb_device"
			return 0
		fi
	done
	return 1
}

_atk_checksum() {
	local sum=0
	local byte
	for byte in "$@"; do
		sum=$(((sum + 16#$byte) & 0xFF))
	done
	printf '%02x' $(((0x55 - sum) & 0xFF))
}

_build_atk_command() {
	local command_id="$1"
	local eeprom_addr_hi="${2}"
	local eeprom_addr_lo="${3}"
	local data_length="$4"
	shift 4
	local data_bytes=("$@")

	local packet=("$ATK_HID_REPORT_ID" "$command_id" "00" "$eeprom_addr_hi" "$eeprom_addr_lo" "$data_length")

	local i
	for ((i = 0; i < 10; i++)); do
		if ((i < ${#data_bytes[@]})); then
			packet+=("${data_bytes[$i]}")
		else
			packet+=("00")
		fi
	done

	local cksum
	cksum=$(_atk_checksum "${packet[@]}")
	packet+=("$cksum")

	echo "${packet[*]}"
}

_send_and_receive_atk_command() {
	local hidraw_path="$1"
	shift
	local packet_hex=("$@")

	python3 -c "
import os, select, sys, time
fd = os.open('$hidraw_path', os.O_RDWR | os.O_NONBLOCK)
try:
    while True:
        r, _, _ = select.select([fd], [], [], 0.02)
        if not r: break
        os.read(fd, 64)

    cmd = bytes([$(printf '0x%s, ' "${packet_hex[@]}")])
    os.write(fd, cmd)

    deadline = time.monotonic() + 3.0
    while time.monotonic() < deadline:
        ready, _, _ = select.select([fd], [], [], 0.1)
        if not ready: continue
        try:
            while True:
                resp = os.read(fd, 64)
                if len(resp) >= 2 and resp[0] == 0x08 and resp[1] in (0x07, 0x08):
                    print(resp.hex(' '))
                    sys.exit(0)
        except BlockingIOError:
            pass
    sys.exit(1)
finally:
    os.close(fd)
"
}

_decode_rate_value() {
	local rate_hi="$1"
	local rate_lo="$2"
	local rate_value="${rate_hi}${rate_lo}"

	case "$rate_value" in
	4015) echo "8000Hz" ;;
	2035) echo "4000Hz" ;;
	1045) echo "2000Hz" ;;
	0154) echo "1000Hz" ;;
	*) echo "unknown (0x${rate_value})" ;;
	esac
}

_get_current_rate() {
	local hidraw_path
	hidraw_path=$(_find_atk_hidraw_config_interface) || exit 1

	local packet_string
	packet_string=$(_build_atk_command "$ATK_CMD_GET_EEPROM" "00" "00" "06")
	read -ra packet_array <<<"$packet_string"

	local response
	response=$(_send_and_receive_atk_command "$hidraw_path" "${packet_array[@]}") || {
		echo "No response from device" >&2
		exit 1
	}

	read -ra response_bytes <<<"$response"
	local rate_hi="${response_bytes[6]}"
	local rate_lo="${response_bytes[7]}"
	local rate_name
	rate_name=$(_decode_rate_value "$rate_hi" "$rate_lo")

	echo "$rate_name"
}

_rate_argument_to_bytes() {
	local rate_arg="$1"
	case "$rate_arg" in
	8k | 8000) echo "$RATE_8K_HI $RATE_8K_LO" ;;
	4k | 4000) echo "$RATE_4K_HI $RATE_4K_LO" ;;
	2k | 2000) echo "$RATE_2K_HI $RATE_2K_LO" ;;
	1k | 1000) echo "$RATE_1K_HI $RATE_1K_LO" ;;
	*)
		echo "Invalid rate: $rate_arg (use 1k, 2k, 4k, or 8k)" >&2
		return 1
		;;
	esac
}

_set_rate() {
	local rate_arg="$1"
	if [[ -z "$rate_arg" ]]; then
		echo "Usage: mouse-poll-rate set <1k|2k|4k|8k>" >&2
		exit 1
	fi

	local rate_bytes
	rate_bytes=$(_rate_argument_to_bytes "$rate_arg") || exit 1
	read -r target_hi target_lo <<<"$rate_bytes"
	local target_name
	target_name=$(_decode_rate_value "$target_hi" "$target_lo")

	local hidraw_path
	hidraw_path=$(_find_atk_hidraw_config_interface) || exit 1

	local get_packet_string
	get_packet_string=$(_build_atk_command "$ATK_CMD_GET_EEPROM" "00" "00" "06")
	read -ra get_packet <<<"$get_packet_string"

	local current_response
	current_response=$(_send_and_receive_atk_command "$hidraw_path" "${get_packet[@]}") || {
		echo "No response from device" >&2
		exit 1
	}

	read -ra current_bytes <<<"$current_response"
	local current_rate_name
	current_rate_name=$(_decode_rate_value "${current_bytes[6]}" "${current_bytes[7]}")
	echo "Current rate: $current_rate_name"

	if [[ "${current_bytes[6]}" == "$target_hi" && "${current_bytes[7]}" == "$target_lo" ]]; then
		echo "Already at $target_name"
		return 0
	fi

	local data_bytes=("$target_hi" "$target_lo" "${current_bytes[8]}" "${current_bytes[9]}" "${current_bytes[10]}" "${current_bytes[11]}")
	local set_packet_string
	set_packet_string=$(_build_atk_command "$ATK_CMD_SET_EEPROM" "00" "00" "06" "${data_bytes[@]}")
	read -ra set_packet <<<"$set_packet_string"

	echo "Setting rate to $target_name..."
	_send_and_receive_atk_command "$hidraw_path" "${set_packet[@]}" >/dev/null || {
		echo "No response (device may have re-enumerated)" >&2
		return 0
	}

	local verify_response
	verify_response=$(_send_and_receive_atk_command "$hidraw_path" "${get_packet[@]}") || {
		echo "Cannot verify (device may have re-enumerated)" >&2
		return 0
	}

	read -ra verify_bytes <<<"$verify_response"
	local new_rate_name
	new_rate_name=$(_decode_rate_value "${verify_bytes[6]}" "${verify_bytes[7]}")
	echo "New rate: $new_rate_name"

	if [[ "${verify_bytes[6]}" == "$target_hi" && "${verify_bytes[7]}" == "$target_lo" ]]; then
		echo "Rate changed successfully"
	else
		echo "Rate verification failed (expected $target_name, got $new_rate_name)" >&2
		return 1
	fi
}

_show_device_info() {
	local usb_device_path
	usb_device_path=$(_find_atk_usb_device_path) || {
		echo "No ATK mouse dongle found" >&2
		exit 1
	}

	local product vendor_id product_id usb_speed usb_version
	product=$(cat "$usb_device_path/product" 2>/dev/null || echo "unknown")
	vendor_id=$(cat "$usb_device_path/idVendor" 2>/dev/null || echo "unknown")
	product_id=$(cat "$usb_device_path/idProduct" 2>/dev/null || echo "unknown")
	usb_speed=$(cat "$usb_device_path/speed" 2>/dev/null || echo "unknown")
	usb_version=$(tr -d ' ' < "$usb_device_path/version" 2>/dev/null || echo "unknown")

	echo "Device: $product"
	echo "USB ID: ${vendor_id}:${product_id}"
	echo "USB Speed: ${usb_speed} Mbps"
	echo "USB Version: $usb_version"

	case "$usb_speed" in
	480) echo "Mode: High Speed (supports up to 8000Hz)" ;;
	12) echo "Mode: Full Speed (max 1000Hz)" ;;
	*) echo "Mode: Unknown" ;;
	esac

	local hidraw_path
	hidraw_path=$(_find_atk_hidraw_config_interface) || {
		echo "Config interface: not found"
		return 0
	}
	echo "Config interface: $hidraw_path"

	local current_rate
	current_rate=$(_get_current_rate 2>/dev/null) || current_rate="unable to read"
	echo "EEPROM poll rate: $current_rate"
}

main "$@"
