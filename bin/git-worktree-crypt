#!/usr/bin/env bash

set -Eeuo pipefail

readonly BRANCH_NAME="${1:?Usage: git-worktree-crypt <branch-name>}"
REPOSITORY_ROOT="$(git rev-parse --show-toplevel)"
readonly REPOSITORY_ROOT
readonly WORKTREE_DIRECTORY="${REPOSITORY_ROOT}/.worktrees/${BRANCH_NAME}"
WORKTREE_BASENAME="$(basename "${WORKTREE_DIRECTORY}")"
readonly WORKTREE_BASENAME

main() {
	cd "${REPOSITORY_ROOT}"
	_create_worktree_with_git_crypt_filters_disabled
	_symlink_git_crypt_keys_into_worktree
	_checkout_files_with_working_smudge_filter
	echo "Worktree ready at ${WORKTREE_DIRECTORY}"
}

_create_worktree_with_git_crypt_filters_disabled() {
	git -c filter.git-crypt.smudge=cat -c filter.git-crypt.clean=cat \
		worktree add --no-checkout -b "${BRANCH_NAME}" "${WORKTREE_DIRECTORY}" main
}

_symlink_git_crypt_keys_into_worktree() {
	local worktree_git_directory="${REPOSITORY_ROOT}/.git/worktrees/${WORKTREE_BASENAME}"
	rm -f "${worktree_git_directory}/git-crypt" 2>/dev/null || true
	ln -s "${REPOSITORY_ROOT}/.git/git-crypt" "${worktree_git_directory}/git-crypt"
}

_checkout_files_with_working_smudge_filter() {
	cd "${WORKTREE_DIRECTORY}"
	git reset --hard HEAD
}

main
