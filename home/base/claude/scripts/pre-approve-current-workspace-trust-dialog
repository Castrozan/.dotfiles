#!/usr/bin/env python3
import json
import os
import sys
import tempfile
from pathlib import Path


def pre_approve_current_workspace_trust_dialog() -> None:
    claude_config_path = Path.home() / ".claude.json"
    if not claude_config_path.exists():
        return

    current_working_directory = os.path.realpath(os.getcwd())

    try:
        claude_config = json.loads(claude_config_path.read_text())
    except (json.JSONDecodeError, OSError):
        return

    projects = claude_config.setdefault("projects", {})
    project_entry = projects.setdefault(current_working_directory, {})

    if project_entry.get("hasTrustDialogAccepted") is True:
        return

    project_entry["hasTrustDialogAccepted"] = True

    write_claude_config_atomically(claude_config_path, claude_config)


def write_claude_config_atomically(
    claude_config_path: Path, claude_config: dict
) -> None:
    with tempfile.NamedTemporaryFile(
        mode="w",
        dir=claude_config_path.parent,
        prefix=".claude.json.",
        suffix=".tmp",
        delete=False,
    ) as temporary_file:
        json.dump(claude_config, temporary_file, indent=2)
        temporary_file.flush()
        os.fsync(temporary_file.fileno())
        temporary_file_path = Path(temporary_file.name)

    os.replace(temporary_file_path, claude_config_path)


if __name__ == "__main__":
    try:
        pre_approve_current_workspace_trust_dialog()
    except Exception:
        sys.exit(0)
