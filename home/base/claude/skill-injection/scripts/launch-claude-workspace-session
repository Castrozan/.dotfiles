#!/usr/bin/env python3

import hashlib
import os
import shutil
import sys
from dataclasses import dataclass
from pathlib import Path

SKILL_DISCOVERY_PRUNED_CHILD_DIRECTORY_NAMES = frozenset(
    {"node_modules", "__pycache__", "target", "dist", "build", "venv", "agent-types"}
)
WORKSPACE_SKILL_NAMESPACE_PARENT_DIRECTORY = Path("/tmp")
WORKSPACE_SKILL_NAMESPACE_DIRECTORY_NAME_PREFIX = "claude-workspace-skills."
WORKSPACE_SKILL_NAMESPACE_SOURCE_CWD_SENTINEL_FILE_NAME = ".source-cwd"
WORKSPACE_SKILL_NAMESPACE_CLAUDE_SKILLS_SUBPATH = Path(".claude") / "skills"
INTERACTIVE_PREFERENCES_FILE_PATH_ENVIRONMENT_VARIABLE_NAME = (
    "CLAUDE_INTERACTIVE_PREFERENCES_PATH"
)
INTERACTIVE_MODEL_ENVIRONMENT_VARIABLE_NAME = "CLAUDE_INTERACTIVE_MODEL"
CLAWDE_BACKGROUND_AGENT_ENVIRONMENT_MARKER = "CLAWDE_RESUME_FLAG"


class WorkspaceLaunchConfigurationError(Exception):
    pass


@dataclass(frozen=True)
class WorkspaceClaudeLaunchPlan:
    workspace_skill_namespace_directory: Path
    discovered_skill_directory_name_map: dict[str, Path]
    command_arguments: list[str]


@dataclass(frozen=True)
class WorkspaceClaudeWrapperArguments:
    requested_skill_source_directories: list[str]
    remaining_claude_arguments: list[str]


def is_child_directory_pruned_from_skill_discovery(child_directory_name: str) -> bool:
    if child_directory_name.startswith("."):
        return True
    if child_directory_name in SKILL_DISCOVERY_PRUNED_CHILD_DIRECTORY_NAMES:
        return True
    return False


def discover_workspace_skill_source_directories(
    workspace_search_root_directory: Path,
) -> list[Path]:
    if not workspace_search_root_directory.is_dir():
        return []
    resolved_workspace_search_root_directory = workspace_search_root_directory.resolve()
    if resolved_workspace_search_root_directory == Path.home().resolve():
        return []
    discovered_skill_source_directories: list[Path] = []
    for (
        currently_walked_directory_path,
        child_directory_names_to_descend,
        child_file_names_in_currently_walked_directory,
    ) in os.walk(resolved_workspace_search_root_directory):
        child_directory_names_to_descend[:] = [
            child_directory_name
            for child_directory_name in child_directory_names_to_descend
            if not is_child_directory_pruned_from_skill_discovery(child_directory_name)
        ]
        if "SKILL.md" in child_file_names_in_currently_walked_directory:
            discovered_skill_source_directories.append(
                Path(currently_walked_directory_path)
            )
    return sorted(
        discovered_skill_source_directories,
        key=lambda discovered_skill_source_directory: (
            len(
                discovered_skill_source_directory.relative_to(
                    resolved_workspace_search_root_directory
                ).parts
            ),
            str(
                discovered_skill_source_directory.relative_to(
                    resolved_workspace_search_root_directory
                )
            ),
        ),
    )


def resolve_requested_skill_source_directories(
    requested_skill_source_directories: list[str],
) -> list[Path]:
    resolved_requested_skill_source_directories: list[Path] = []
    for requested_skill_source_directory in requested_skill_source_directories:
        resolved_requested_skill_source_directory = (
            Path(requested_skill_source_directory).expanduser().resolve()
        )
        if not resolved_requested_skill_source_directory.is_dir():
            raise WorkspaceLaunchConfigurationError(
                f"'{requested_skill_source_directory}' is not a valid directory"
            )
        if not (resolved_requested_skill_source_directory / "SKILL.md").is_file():
            raise WorkspaceLaunchConfigurationError(
                f"no SKILL.md found at root of {requested_skill_source_directory}"
            )
        resolved_requested_skill_source_directories.append(
            resolved_requested_skill_source_directory
        )
    return resolved_requested_skill_source_directories


def scrub_interactive_only_environment_for_clawde_background_agent() -> None:
    if CLAWDE_BACKGROUND_AGENT_ENVIRONMENT_MARKER not in os.environ:
        return
    os.environ.pop(INTERACTIVE_PREFERENCES_FILE_PATH_ENVIRONMENT_VARIABLE_NAME, None)
    os.environ.pop(INTERACTIVE_MODEL_ENVIRONMENT_VARIABLE_NAME, None)


def build_interactive_preferences_system_prompt_arguments() -> list[str]:
    interactive_preferences_file_path_value = os.environ.get(
        INTERACTIVE_PREFERENCES_FILE_PATH_ENVIRONMENT_VARIABLE_NAME
    )
    if not interactive_preferences_file_path_value:
        return []
    interactive_preferences_file_path = Path(interactive_preferences_file_path_value)
    if not interactive_preferences_file_path.is_file():
        return []
    interactive_preferences_content = (
        interactive_preferences_file_path.read_text().strip()
    )
    if not interactive_preferences_content:
        return []
    return ["--append-system-prompt", interactive_preferences_content]


def build_interactive_model_selection_arguments() -> list[str]:
    interactive_model_value = os.environ.get(
        INTERACTIVE_MODEL_ENVIRONMENT_VARIABLE_NAME
    )
    if not interactive_model_value:
        return []
    return ["--model", interactive_model_value]


def build_unique_skill_directory_name_map(
    skill_source_directories: list[Path],
) -> dict[str, Path]:
    unique_skill_directory_name_map: dict[str, Path] = {}
    for skill_source_directory in skill_source_directories:
        skill_directory_name = skill_source_directory.name
        if skill_directory_name in unique_skill_directory_name_map:
            continue
        unique_skill_directory_name_map[skill_directory_name] = skill_source_directory
    return unique_skill_directory_name_map


def compute_workspace_skill_namespace_directory(
    workspace_source_cwd: Path,
) -> Path:
    workspace_source_cwd_hash = hashlib.sha256(
        str(workspace_source_cwd.resolve()).encode()
    ).hexdigest()[:12]
    return (
        WORKSPACE_SKILL_NAMESPACE_PARENT_DIRECTORY
        / f"{WORKSPACE_SKILL_NAMESPACE_DIRECTORY_NAME_PREFIX}{workspace_source_cwd_hash}"
    )


def ensure_directory_symlink(target_path: Path, source_path: Path) -> None:
    if target_path.is_symlink():
        target_path.unlink()
    elif target_path.exists():
        if target_path.is_dir():
            shutil.rmtree(target_path)
        else:
            target_path.unlink()
    target_path.symlink_to(source_path, target_is_directory=source_path.is_dir())


def remove_workspace_skill_namespace_directory_in_place(
    workspace_skill_namespace_directory: Path,
) -> None:
    if workspace_skill_namespace_directory.is_symlink():
        workspace_skill_namespace_directory.unlink()
        return
    if workspace_skill_namespace_directory.exists():
        shutil.rmtree(workspace_skill_namespace_directory)


def sweep_stale_workspace_skill_namespace_directories() -> None:
    if not WORKSPACE_SKILL_NAMESPACE_PARENT_DIRECTORY.is_dir():
        return
    for candidate_directory in WORKSPACE_SKILL_NAMESPACE_PARENT_DIRECTORY.iterdir():
        if candidate_directory.is_symlink():
            continue
        if not candidate_directory.is_dir():
            continue
        if not candidate_directory.name.startswith(
            WORKSPACE_SKILL_NAMESPACE_DIRECTORY_NAME_PREFIX
        ):
            continue
        source_cwd_sentinel_file = (
            candidate_directory
            / WORKSPACE_SKILL_NAMESPACE_SOURCE_CWD_SENTINEL_FILE_NAME
        )
        if not source_cwd_sentinel_file.is_file():
            shutil.rmtree(candidate_directory)
            continue
        recorded_source_cwd = Path(source_cwd_sentinel_file.read_text().strip())
        if not recorded_source_cwd.is_dir():
            shutil.rmtree(candidate_directory)


def populate_workspace_skill_namespace_directory(
    workspace_skill_namespace_directory: Path,
    discovered_skill_directory_name_map: dict[str, Path],
    workspace_source_cwd: Path,
) -> None:
    workspace_claude_skills_directory = (
        workspace_skill_namespace_directory
        / WORKSPACE_SKILL_NAMESPACE_CLAUDE_SKILLS_SUBPATH
    )
    workspace_claude_skills_directory.mkdir(parents=True)
    (
        workspace_skill_namespace_directory
        / WORKSPACE_SKILL_NAMESPACE_SOURCE_CWD_SENTINEL_FILE_NAME
    ).write_text(str(workspace_source_cwd.resolve()) + "\n")
    for (
        discovered_skill_directory_name,
        discovered_skill_source_directory,
    ) in discovered_skill_directory_name_map.items():
        ensure_directory_symlink(
            workspace_claude_skills_directory / discovered_skill_directory_name,
            discovered_skill_source_directory,
        )


def prepare_workspace_claude_launch_plan(
    workspace_search_root_directory: Path,
    requested_skill_source_directories: list[str],
    claude_binary_path: str,
) -> WorkspaceClaudeLaunchPlan:
    if requested_skill_source_directories:
        skill_source_directories = resolve_requested_skill_source_directories(
            requested_skill_source_directories
        )
    else:
        skill_source_directories = discover_workspace_skill_source_directories(
            workspace_search_root_directory
        )

    discovered_skill_directory_name_map = build_unique_skill_directory_name_map(
        skill_source_directories
    )

    workspace_skill_namespace_directory = compute_workspace_skill_namespace_directory(
        workspace_search_root_directory
    )

    command_arguments = [claude_binary_path]
    command_arguments.extend(build_interactive_model_selection_arguments())
    command_arguments.extend(build_interactive_preferences_system_prompt_arguments())
    if discovered_skill_directory_name_map:
        command_arguments.extend(
            ["--add-dir", str(workspace_skill_namespace_directory)]
        )

    return WorkspaceClaudeLaunchPlan(
        workspace_skill_namespace_directory=workspace_skill_namespace_directory,
        discovered_skill_directory_name_map=discovered_skill_directory_name_map,
        command_arguments=command_arguments,
    )


def materialize_workspace_skill_namespace_directory_on_disk(
    workspace_claude_launch_plan: WorkspaceClaudeLaunchPlan,
    workspace_source_cwd: Path,
) -> None:
    sweep_stale_workspace_skill_namespace_directories()
    remove_workspace_skill_namespace_directory_in_place(
        workspace_claude_launch_plan.workspace_skill_namespace_directory
    )
    if not workspace_claude_launch_plan.discovered_skill_directory_name_map:
        return
    populate_workspace_skill_namespace_directory(
        workspace_claude_launch_plan.workspace_skill_namespace_directory,
        workspace_claude_launch_plan.discovered_skill_directory_name_map,
        workspace_source_cwd,
    )


def parse_workspace_claude_wrapper_arguments(
    command_line_arguments: list[str],
) -> WorkspaceClaudeWrapperArguments:
    requested_skill_source_directories: list[str] = []
    remaining_claude_arguments: list[str] = []
    current_argument_index = 0

    while current_argument_index < len(command_line_arguments):
        current_argument = command_line_arguments[current_argument_index]
        if current_argument == "--from":
            if current_argument_index + 1 >= len(command_line_arguments):
                raise WorkspaceLaunchConfigurationError(
                    "--from requires a directory argument"
                )
            requested_skill_source_directories.append(
                command_line_arguments[current_argument_index + 1]
            )
            current_argument_index += 2
            continue
        if current_argument == "--":
            remaining_claude_arguments.extend(
                command_line_arguments[current_argument_index + 1 :]
            )
            break
        remaining_claude_arguments.append(current_argument)
        current_argument_index += 1

    return WorkspaceClaudeWrapperArguments(
        requested_skill_source_directories=requested_skill_source_directories,
        remaining_claude_arguments=remaining_claude_arguments,
    )


def exec_claude_with_workspace_skills(
    workspace_claude_launch_plan: WorkspaceClaudeLaunchPlan,
    remaining_claude_arguments: list[str],
) -> None:
    full_command_arguments = (
        workspace_claude_launch_plan.command_arguments + remaining_claude_arguments
    )
    os.execvp(full_command_arguments[0], full_command_arguments)


def main() -> None:
    try:
        scrub_interactive_only_environment_for_clawde_background_agent()
        workspace_claude_wrapper_arguments = parse_workspace_claude_wrapper_arguments(
            sys.argv[1:]
        )
        claude_binary_path = os.environ.get("CLAUDE_BINARY_PATH", "claude")
        workspace_search_root_directory = Path.cwd()

        workspace_claude_launch_plan = prepare_workspace_claude_launch_plan(
            workspace_search_root_directory=workspace_search_root_directory,
            requested_skill_source_directories=workspace_claude_wrapper_arguments.requested_skill_source_directories,
            claude_binary_path=claude_binary_path,
        )
        materialize_workspace_skill_namespace_directory_on_disk(
            workspace_claude_launch_plan,
            workspace_search_root_directory,
        )
        exec_claude_with_workspace_skills(
            workspace_claude_launch_plan,
            workspace_claude_wrapper_arguments.remaining_claude_arguments,
        )
    except WorkspaceLaunchConfigurationError as workspace_launch_configuration_error:
        print(
            f"error: {workspace_launch_configuration_error}",
            file=sys.stderr,
        )
        sys.exit(1)


if __name__ == "__main__":
    main()
