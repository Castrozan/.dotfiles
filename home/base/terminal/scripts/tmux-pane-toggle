#!/usr/bin/env bash
# Usage: tmux-pane-toggle <pane_title> <command_to_run> [working_directory]
# Toggles a named pane in the current tmux window. First press splits and
# runs <command_to_run> in a maximised pane titled <pane_title>. Second
# press hides it. When the command exits, the pane is destroyed and focus
# returns to the previous pane (re-zoomed if it was zoomed before).

[ "${DEBUG:-}" = "1" ] && set -x
set -eu

if [ "$#" -lt 2 ]; then
	echo "usage: tmux-pane-toggle <pane_title> <command_to_run> [working_directory]" >&2
	exit 2
fi

pane_title="$1"
command_to_run="$2"
working_directory="${3:-$(tmux display-message -p '#{pane_current_path}')}"

current_window_id=$(tmux display-message -p '#{window_id}')
current_pane_id=$(tmux display-message -p '#{pane_id}')

existing_pane_id=$(
	tmux list-panes -t "$current_window_id" -F '#{pane_id} #{pane_title}' 2>/dev/null |
		{ grep -E "^%[0-9]+ ${pane_title}$" || true; } |
		cut -d' ' -f1 |
		head -n1
)

if [ -n "$existing_pane_id" ]; then
	tmux select-pane -t "$existing_pane_id"
	tmux resize-pane -Z
	exit 0
fi

previous_pane_id="$current_pane_id"
previous_pane_was_zoomed=$(tmux display-message -p -t "$previous_pane_id" '#{pane_zoomed}')

if ! new_pane_id=$(tmux split-window -v -c "$working_directory" -P -F '#{pane_id}' 2>&1); then
	tmux display-message -d 3000 "Error: Failed to create pane: $new_pane_id"
	exit 1
fi

tmux select-pane -t "$new_pane_id" -T "$pane_title"
tmux resize-pane -Z -t "$new_pane_id"

if [ "$previous_pane_was_zoomed" = "1" ]; then
	restore_command="tmux kill-pane -t $new_pane_id ; tmux select-pane -t $previous_pane_id ; tmux resize-pane -Z -t $previous_pane_id"
else
	restore_command="tmux kill-pane -t $new_pane_id ; tmux select-pane -t $previous_pane_id"
fi

cleanup_command="$command_to_run; tmux run-shell -b '$restore_command'"

tmux send-keys -t "$new_pane_id" "$cleanup_command" Enter
