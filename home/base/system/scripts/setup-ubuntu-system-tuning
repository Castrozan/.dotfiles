#!/usr/bin/env bash

set -Eeuo pipefail

readonly SERVICES_TO_DISABLE=(
	ModemManager
	accounts-daemon
	avahi-daemon
	cups
	cups-browsed
	kerneloops
	wpa_supplicant
	NetworkManager-wait-online
	switcheroo-control
	rsyslog
	glances
	auditd
)
readonly VFS_CACHE_PRESSURE_VALUE=50
readonly SYSCTL_CONFIG_PATH="/etc/sysctl.d/99-vfs-cache-pressure.conf"
readonly GRUB_DEFAULT_PATH="/etc/default/grub"
readonly JOURNALD_CONFIG_DIR="/etc/systemd/journald.conf.d"
readonly JOURNALD_CONFIG_PATH="${JOURNALD_CONFIG_DIR}/size-cap.conf"
readonly JOURNAL_MAX_SIZE="500M"

main() {
	echo "=== Ubuntu System Tuning ==="
	echo ""

	_disable_unnecessary_services
	_set_vfs_cache_pressure
	_disable_kernel_audit
	_remove_snapd
	_configure_journal_size_cap

	echo ""
	echo "=== Done ==="
	echo "Tuning applied:"
	echo "  - Unnecessary services disabled"
	echo "  - vm.vfs_cache_pressure=${VFS_CACHE_PRESSURE_VALUE}"
	echo "  - Kernel audit disabled"
	echo "  - snapd removed"
	echo "  - Journal capped at ${JOURNAL_MAX_SIZE}"
	echo ""
	echo "Verify with:"
	echo "  systemctl is-active ModemManager avahi-daemon cups"
	echo "  sysctl vm.vfs_cache_pressure"
	echo "  cat ${JOURNALD_CONFIG_PATH}"
}

_disable_unnecessary_services() {
	echo "[1/5] Disabling unnecessary services..."
	for service_name in "${SERVICES_TO_DISABLE[@]}"; do
		if systemctl list-unit-files "${service_name}.service" &>/dev/null; then
			sudo systemctl disable --now "${service_name}" 2>/dev/null || true
			echo "  ${service_name}: disabled"
		else
			echo "  ${service_name}: not installed, skipping"
		fi
	done
}

_set_vfs_cache_pressure() {
	echo "[2/5] Setting vm.vfs_cache_pressure to ${VFS_CACHE_PRESSURE_VALUE}..."
	echo "vm.vfs_cache_pressure=${VFS_CACHE_PRESSURE_VALUE}" | sudo tee "$SYSCTL_CONFIG_PATH" >/dev/null
	if sudo sysctl -w "vm.vfs_cache_pressure=${VFS_CACHE_PRESSURE_VALUE}" 2>/dev/null; then
		echo "  vm.vfs_cache_pressure=${VFS_CACHE_PRESSURE_VALUE} (applied live)"
	else
		echo "  vm.vfs_cache_pressure=${VFS_CACHE_PRESSURE_VALUE} (will apply on next boot)"
	fi
}

_disable_kernel_audit() {
	echo "[3/5] Disabling kernel audit..."

	if sudo auditctl -e 0 2>/dev/null; then
		echo "  Audit disabled (live)"
	else
		echo "  auditctl not available, skipping live disable"
	fi

	if [ -f "$GRUB_DEFAULT_PATH" ]; then
		if grep -q "^GRUB_CMDLINE_LINUX_DEFAULT=.*audit=0" "$GRUB_DEFAULT_PATH"; then
			echo "  audit=0 already in GRUB config"
		else
			sudo sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT="\(.*\)"/GRUB_CMDLINE_LINUX_DEFAULT="\1 audit=0"/' "$GRUB_DEFAULT_PATH"
			sudo update-grub 2>/dev/null || true
			echo "  audit=0 added to GRUB config (takes effect on next boot)"
		fi
	else
		echo "  ${GRUB_DEFAULT_PATH} not found, skipping GRUB config"
	fi
}

_remove_snapd() {
	echo "[4/5] Removing snapd..."
	if command -v snap &>/dev/null; then
		sudo apt-get remove --purge -y -qq snapd 2>/dev/null || true
		sudo rm -rf /snap /var/snap /var/lib/snapd /var/cache/snapd
		echo "  snapd removed and directories cleaned"
	else
		echo "  snapd not installed, skipping"
	fi
}

_configure_journal_size_cap() {
	echo "[5/5] Configuring journal size cap to ${JOURNAL_MAX_SIZE}..."
	sudo mkdir -p "$JOURNALD_CONFIG_DIR"
	sudo tee "$JOURNALD_CONFIG_PATH" >/dev/null <<CONF
[Journal]
SystemMaxUse=${JOURNAL_MAX_SIZE}
CONF
	if command -v systemctl &>/dev/null; then
		sudo systemctl restart systemd-journald
		echo "  journald restarted with size cap"
	else
		echo "  Config written, will apply on next boot"
	fi
}

main "$@"
