#!/usr/bin/env bash

set -Eeuo pipefail

readonly DOTFILES_DIR="${HOME}/.dotfiles"
readonly BACKUP_PREFIX="backup"
readonly NIXOS_ALLOW_UNFREE="NIXPKGS_ALLOW_UNFREE=1"
readonly REBUILD_WRAPPER_SENTINEL="DOTFILES_REBUILD_WRAPPER=1"
readonly AGENIX_IDENTITY_KEY="${HOME}/.ssh/id_ed25519"
readonly NIXOS_SETUID_WRAPPERS_DIR="/run/wrappers/bin"
readonly ZANONI_SYSTEM_FLAKE="${ZANONI_SYSTEM_FLAKE:-${HOME}/zanoni-system/flake.nix}"
readonly ETC_NIXOS_FLAKE="${ETC_NIXOS_FLAKE:-/etc/nixos/flake.nix}"

_sudo() {
	local sudo_bin="sudo"
	if [ -x "${NIXOS_SETUID_WRAPPERS_DIR}/sudo" ]; then
		sudo_bin="${NIXOS_SETUID_WRAPPERS_DIR}/sudo"
	fi

	"$sudo_bin" -n "$@"
}

_ensure_setuid_wrappers_in_path() {
	if [ -d "$NIXOS_SETUID_WRAPPERS_DIR" ]; then
		case ":$PATH:" in
		*":${NIXOS_SETUID_WRAPPERS_DIR}:"*) ;;
		*) export PATH="${NIXOS_SETUID_WRAPPERS_DIR}:${PATH}" ;;
		esac
	fi
}

main() {
	_ensure_setuid_wrappers_in_path
	_rebuild_system
	_reload_hyprland || true
}

_rebuild_system() {
	echo ":: Rebuilding system configuration using dotfiles..."

	_ensure_nix_in_path_or_source_daemon_profile || {
		echo "Error: nix is not available in PATH and nix-daemon profile was not found." >&2
		return 1
	}

	_ensure_dotfiles_dir_exists || return 1
	_init_git_submodules_if_present "$DOTFILES_DIR" || true

	_source_os_release || return 1
	_fix_agenix_identity_key_ownership

	if _is_nixos; then
		_rebuild_nixos
	else
		_rebuild_home_manager
	fi
}

_ensure_nix_in_path_or_source_daemon_profile() {
	if command -v nix >/dev/null 2>&1; then
		return 0
	fi

	local daemon_profile="/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
	if [ -f "$daemon_profile" ]; then
		# shellcheck disable=SC1090
		. "$daemon_profile"
	fi

	command -v nix >/dev/null 2>&1
}

_ensure_dotfiles_dir_exists() {
	if [ ! -d "$DOTFILES_DIR" ]; then
		echo "Error: dotfiles directory not found at: $DOTFILES_DIR" >&2
		return 1
	fi
}

_init_git_submodules_if_present() {
	local dir=$1
	if [ -f "$dir/.gitmodules" ]; then
		git -C "$dir" submodule update --init --recursive 2>/dev/null || true
	fi
}

_source_os_release() {
	if [ ! -f /etc/os-release ]; then
		echo "Error: /etc/os-release not found. Cannot detect OS." >&2
		return 1
	fi

	# shellcheck disable=SC1091
	. /etc/os-release
}

_is_nixos() {
	[ "${ID:-}" = "nixos" ]
}

_fix_agenix_identity_key_ownership() {
	[ -f "$AGENIX_IDENTITY_KEY" ] || return 0

	local current_owner expected_owner
	current_owner="$(stat -c '%U' "$AGENIX_IDENTITY_KEY")"
	expected_owner="$(whoami)"

	[ "$current_owner" = "$expected_owner" ] && return 0

	echo ":: Fixing agenix identity key ownership ($current_owner -> $expected_owner)..."
	_sudo chown "$expected_owner" "$AGENIX_IDENTITY_KEY"
	_sudo chmod 600 "$AGENIX_IDENTITY_KEY"
	if [ -f "$AGENIX_IDENTITY_KEY.pub" ]; then
		_sudo chown "$expected_owner" "$AGENIX_IDENTITY_KEY.pub"
		_sudo chmod 644 "$AGENIX_IDENTITY_KEY.pub"
	fi
}

_resolve_machine_alias() {
	local username arch
	username="$(whoami)"
	arch="$(uname -m)"

	case "${username}/${arch}" in
	zanoni/x86_64) echo "chise" ;;
	*)
		echo "Unable to resolve machine alias for ${username}/${arch}" >&2
		exit 1
		;;
	esac
}

_etc_nixos_flake_present() {
	[ -f "$ETC_NIXOS_FLAKE" ]
}

_zanoni_system_flake_present() {
	[ -f "$ZANONI_SYSTEM_FLAKE" ]
}

_etc_nixos_flake_matches_zanoni_system() {
	cmp -s "$ZANONI_SYSTEM_FLAKE" "$ETC_NIXOS_FLAKE"
}

_sync_etc_nixos_flake_from_zanoni_system() {
	local machine_alias="$1"

	[ "$machine_alias" = "chise" ] || return 0
	_zanoni_system_flake_present || return 0
	_etc_nixos_flake_matches_zanoni_system && return 0

	echo ":: Syncing ${ETC_NIXOS_FLAKE} from zanoni-system entrypoint (${ZANONI_SYSTEM_FLAKE})..."
	_sudo install -D -m 0644 "$ZANONI_SYSTEM_FLAKE" "$ETC_NIXOS_FLAKE"
}

_resolve_nixos_flake_ref() {
	local machine_alias="$1"

	if _etc_nixos_flake_present; then
		echo "/etc/nixos#${machine_alias}"
	else
		echo "${DOTFILES_DIR}?submodules=1#${machine_alias}"
	fi
}

_assert_chise_not_deploying_from_bare_dotfiles() {
	local machine_alias="$1"

	[ "$machine_alias" = "chise" ] || return 0
	_etc_nixos_flake_present && return 0

	echo "Error: refusing to deploy chise from bare ${DOTFILES_DIR}." >&2
	echo "       chise must deploy via /etc/nixos#chise, the zanoni-system entrypoint that layers the openclaw overlay onto dotfiles." >&2
	echo "       Bare dotfiles carries no openclaw by design, so this would strip openclaw-gateway.service and take clever+jarvis offline." >&2
	echo "       Restore /etc/nixos/flake.nix (a copy of ~/zanoni-system/flake.nix) and retry." >&2
	return 1
}

_rebuild_nixos() {
	local machine_alias flake_ref
	machine_alias="$(_resolve_machine_alias)"
	_sync_etc_nixos_flake_from_zanoni_system "$machine_alias"
	_assert_chise_not_deploying_from_bare_dotfiles "$machine_alias" || return 1
	flake_ref="$(_resolve_nixos_flake_ref "$machine_alias")"

	echo ":: Detected NixOS. Running nixos-rebuild switch..."
	echo ":: Flake: ${flake_ref}"

	local -a lock_flags=()
	if _etc_nixos_flake_present; then
		lock_flags+=(--no-write-lock-file)
	fi

	_sudo env "PATH=${NIXOS_SETUID_WRAPPERS_DIR}:${PATH}" "$NIXOS_ALLOW_UNFREE" "$REBUILD_WRAPPER_SENTINEL" nixos-rebuild switch --flake "${flake_ref}" "${lock_flags[@]}"
}

_rebuild_home_manager() {
	local config
	config="$(_resolve_machine_alias)"

	echo ":: Detected non-NixOS. Running home-manager switch..."
	echo ":: Flake: ${DOTFILES_DIR}#${config}"

	_hm_switch_with_rate_limit_fallback "$config"
}

_hm_switch_with_rate_limit_fallback() {
	local config=$1
	local flake_ref="${DOTFILES_DIR}?submodules=1#${config}"

	export HOME_MANAGER_BACKUP_OVERWRITE=1

	if command -v home-manager >/dev/null 2>&1; then
		home-manager switch --flake "$flake_ref" -b "$BACKUP_PREFIX"
		return 0
	fi

	if nix run nixpkgs#home-manager -- switch --flake "$flake_ref" -b "$BACKUP_PREFIX" 2>/dev/null; then
		return 0
	fi

	echo "Warning: Falling back to GitHub source may hit rate limits." >&2
	echo "Tip: Install home-manager to avoid this:" >&2
	echo "  nix profile install nixpkgs#home-manager" >&2

	nix run home-manager/master -- switch --flake "$flake_ref" -b "$BACKUP_PREFIX"
}

_reload_hyprland() {
	command -v hyprctl >/dev/null 2>&1 || return 0
	local hypr_dir
	hypr_dir="/run/user/$(id -u)/hypr"
	[ -d "$hypr_dir" ] && [ "$(ls -A "$hypr_dir" 2>/dev/null)" ] || return 0
	echo ":: Reloading Hyprland (config-only, no monitor re-apply)..."
	hyprctl reload config-only
	hypr-apply-theme-colors
	echo ":: Hyprland config refreshed."
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
	main "$@"
fi
