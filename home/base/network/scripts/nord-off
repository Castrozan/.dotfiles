#!/usr/bin/env bash
set -Eeuo pipefail

readonly TAILSCALE_SETTLE_SECONDS=2

_restart_tailscale_if_enabled() {
	if systemctl is-enabled --quiet tailscaled 2>/dev/null; then
		echo "Restarting Tailscale service..."
		systemctl start tailscaled
		sleep "$TAILSCALE_SETTLE_SECONDS"
		echo "Tailscale restarted"
	fi
}

_disconnect_nordvpn() {
	echo "Disconnecting from NordVPN..."
	wgnord d
	_restart_tailscale_if_enabled
	echo "Disconnected from NordVPN"
}

_disconnect_nordvpn
