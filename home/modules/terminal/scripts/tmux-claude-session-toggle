#!/usr/bin/env bash
[ "${DEBUG:-}" = "1" ] && set -x
set -eu

current_window_id=$(tmux display-message -p '#{window_id}')
current_pane_id=$(tmux display-message -p '#{pane_id}')
current_pane_path=$(tmux display-message -p '#{pane_current_path}')

existing_viewer_pane_id=$(tmux list-panes -t "$current_window_id" -F '#{pane_id} #{pane_title}' 2>/dev/null |
	{ grep -E '^%[0-9]+ claude-session-viewer$' || true; } |
	cut -d' ' -f1 |
	head -n1)

if [ -n "$existing_viewer_pane_id" ]; then
	tmux select-pane -t "$existing_viewer_pane_id"
	tmux resize-pane -Z
	exit 0
fi

previous_pane_id="$current_pane_id"
previous_pane_was_zoomed=$(tmux display-message -p -t "$previous_pane_id" '#{pane_zoomed}')

if ! viewer_pane_id=$(tmux split-window -v -c "$current_pane_path" -P -F '#{pane_id}' 2>&1); then
	tmux display-message -d 3000 "Error: Failed to create viewer pane: $viewer_pane_id"
	exit 1
fi

tmux select-pane -t "$viewer_pane_id" -T "claude-session-viewer" 2>/dev/null || exit 1
tmux resize-pane -Z -t "$viewer_pane_id" 2>/dev/null || exit 1

viewer_command="claude-show-session | LESS='-R +G' less"

if [ "$previous_pane_was_zoomed" = "1" ]; then
	cleanup_command="$viewer_command; tmux kill-pane -t $viewer_pane_id 2>/dev/null && sleep 0.1 && tmux select-pane -t $previous_pane_id 2>/dev/null && tmux resize-pane -Z -t $previous_pane_id 2>/dev/null || true"
else
	cleanup_command="$viewer_command; tmux kill-pane -t $viewer_pane_id 2>/dev/null && tmux select-pane -t $previous_pane_id 2>/dev/null || true"
fi

tmux send-keys -t "$viewer_pane_id" "$cleanup_command" Enter 2>/dev/null || exit 1
