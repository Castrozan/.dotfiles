#!/usr/bin/env bash

set -Eeuo pipefail

readonly LOGIND_DROP_IN_DIR="/etc/systemd/logind.conf.d"
readonly LOGIND_DROP_IN_FILE="${LOGIND_DROP_IN_DIR}/lid-switch.conf"

main() {
	echo "=== Lid Switch Configuration ==="
	echo ""

	_create_logind_drop_in
	_restart_logind

	echo ""
	echo "=== Done ==="
	echo "Lid switch actions set to ignore (close lid without suspend)"
}

_create_logind_drop_in() {
	echo "[1/2] Writing logind drop-in to ignore lid switch..."
	sudo mkdir -p "$LOGIND_DROP_IN_DIR"
	sudo tee "$LOGIND_DROP_IN_FILE" >/dev/null <<CONF
[Login]
HandleLidSwitch=ignore
HandleLidSwitchExternalPower=ignore
HandleLidSwitchDocked=ignore
CONF
	echo "  wrote $LOGIND_DROP_IN_FILE"
}

_restart_logind() {
	echo "[2/2] Restarting systemd-logind..."
	if sudo systemctl restart systemd-logind 2>/dev/null; then
		echo "  systemd-logind restarted"
	else
		echo "  restart failed, changes apply on next boot"
	fi
}

main "$@"
