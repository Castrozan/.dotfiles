#!/usr/bin/env bash

set -Eeuo pipefail

readonly DOTFILES_DIR="${HOME}/.dotfiles"
readonly BACKUP_PREFIX="backup"
readonly NIXOS_ALLOW_UNFREE="NIXPKGS_ALLOW_UNFREE=1"
readonly AGENIX_IDENTITY_KEY="${HOME}/.ssh/id_ed25519"
readonly NIXOS_SETUID_WRAPPERS_DIR="/run/wrappers/bin"

_ensure_setuid_wrappers_in_path() {
	if [ -d "$NIXOS_SETUID_WRAPPERS_DIR" ]; then
		case ":$PATH:" in
		*":${NIXOS_SETUID_WRAPPERS_DIR}:"*) ;;
		*) export PATH="${NIXOS_SETUID_WRAPPERS_DIR}:${PATH}" ;;
		esac
	fi
}

main() {
	_ensure_setuid_wrappers_in_path
	_rebuild_system
	_reload_hyprland || true
	_restart_quickshell_services || true
}

_rebuild_system() {
	echo ":: Rebuilding system configuration using dotfiles..."

	_ensure_nix_in_path_or_source_daemon_profile || {
		echo "Error: nix is not available in PATH and nix-daemon profile was not found." >&2
		return 1
	}

	_ensure_dotfiles_dir_exists || return 1
	_init_git_submodules_if_present "$DOTFILES_DIR" || true

	_source_os_release || return 1
	_fix_agenix_identity_key_ownership

	if _is_nixos; then
		_rebuild_nixos
	else
		_rebuild_home_manager
	fi
}

_ensure_nix_in_path_or_source_daemon_profile() {
	if command -v nix >/dev/null 2>&1; then
		return 0
	fi

	local daemon_profile="/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
	if [ -f "$daemon_profile" ]; then
		# shellcheck disable=SC1090
		. "$daemon_profile"
	fi

	command -v nix >/dev/null 2>&1
}

_ensure_dotfiles_dir_exists() {
	if [ ! -d "$DOTFILES_DIR" ]; then
		echo "Error: dotfiles directory not found at: $DOTFILES_DIR" >&2
		return 1
	fi
}

_init_git_submodules_if_present() {
	local dir=$1
	if [ -f "$dir/.gitmodules" ]; then
		git -C "$dir" submodule update --init --recursive 2>/dev/null || true
	fi
}

_source_os_release() {
	if [ ! -f /etc/os-release ]; then
		echo "Error: /etc/os-release not found. Cannot detect OS." >&2
		return 1
	fi

	# shellcheck disable=SC1091
	. /etc/os-release
}

_is_nixos() {
	[ "${ID:-}" = "nixos" ]
}

_fix_agenix_identity_key_ownership() {
	[ -f "$AGENIX_IDENTITY_KEY" ] || return 0

	local current_owner expected_owner
	current_owner="$(stat -c '%U' "$AGENIX_IDENTITY_KEY")"
	expected_owner="$(whoami)"

	[ "$current_owner" = "$expected_owner" ] && return 0

	echo ":: Fixing agenix identity key ownership ($current_owner -> $expected_owner)..."
	sudo chown "$expected_owner" "$AGENIX_IDENTITY_KEY"
	sudo chmod 600 "$AGENIX_IDENTITY_KEY"
	if [ -f "$AGENIX_IDENTITY_KEY.pub" ]; then
		sudo chown "$expected_owner" "$AGENIX_IDENTITY_KEY.pub"
		sudo chmod 644 "$AGENIX_IDENTITY_KEY.pub"
	fi
}

_rebuild_nixos() {
	local username dotfiles_path
	username="$(whoami)"
	dotfiles_path="$DOTFILES_DIR"

	echo ":: Detected NixOS. Running nixos-rebuild switch..."
	echo ":: Flake: ${dotfiles_path}#${username}"

	sudo env "$NIXOS_ALLOW_UNFREE" nixos-rebuild switch --flake "${dotfiles_path}?submodules=1#${username}"
}

_rebuild_home_manager() {
	local config
	config="$(_build_home_manager_config_name)"

	echo ":: Detected non-NixOS. Running home-manager switch..."
	echo ":: Flake: ${DOTFILES_DIR}#${config}"

	_hm_switch_with_rate_limit_fallback "$config"
}

_build_home_manager_config_name() {
	local username arch system
	username="$(whoami)"
	arch="$(uname -m)"

	local os_suffix="linux"

	case "$arch" in
	x86_64) system="x86_64-${os_suffix}" ;;
	aarch64 | arm64) system="aarch64-${os_suffix}" ;;
	*) system="${arch}-${os_suffix}" ;;
	esac

	echo "${username}@${system}"
}

_hm_switch_with_rate_limit_fallback() {
	local config=$1
	local flake_ref="${DOTFILES_DIR}?submodules=1#${config}"

	export HOME_MANAGER_BACKUP_OVERWRITE=1

	if command -v home-manager >/dev/null 2>&1; then
		home-manager switch --flake "$flake_ref" -b "$BACKUP_PREFIX"
		return 0
	fi

	if nix run nixpkgs#home-manager -- switch --flake "$flake_ref" -b "$BACKUP_PREFIX" 2>/dev/null; then
		return 0
	fi

	echo "Warning: Falling back to GitHub source may hit rate limits." >&2
	echo "Tip: Install home-manager to avoid this:" >&2
	echo "  nix profile install nixpkgs#home-manager" >&2

	nix run home-manager/master -- switch --flake "$flake_ref" -b "$BACKUP_PREFIX"
}

_restart_quickshell_services() {
	command -v systemctl >/dev/null 2>&1 || return 0
	local quickshell_services
	quickshell_services="$(systemctl --user list-units --type=service --plain --no-legend 'quickshell-*' 2>/dev/null | awk '{print $1}')"
	[ -n "$quickshell_services" ] || return 0
	echo ":: Restarting quickshell services..."
	echo "$quickshell_services" | xargs systemctl --user restart
}

_reload_hyprland() {
	command -v hyprctl >/dev/null 2>&1 || return 0
	local hypr_dir
	hypr_dir="/run/user/$(id -u)/hypr"
	[ -d "$hypr_dir" ] && [ "$(ls -A "$hypr_dir" 2>/dev/null)" ] || return 0
	echo ":: Reloading Hyprland (config-only, no monitor re-apply)..."
	hyprctl reload config-only
	hypr-apply-theme-colors
	echo ":: Hyprland config refreshed."
}

main "$@"
