#!/usr/bin/env bash

if [[ -z $1 ]]; then
	echo "Usage: hypr-theme-set <theme-name>"
	exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/hypr-theme/current/theme"
NEXT_THEME_PATH="$HOME/.config/hypr-theme/current/next-theme"
USER_THEMES_PATH="$HOME/.config/hypr-theme/user-themes"
HYPR_THEMES_PATH="$HOME/.config/hypr/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ -e "$USER_THEMES_PATH/$THEME_NAME" ]]; then
	THEME_PATH="$USER_THEMES_PATH/$THEME_NAME"
elif [[ -e "$HYPR_THEMES_PATH/$THEME_NAME" ]]; then
	THEME_PATH="$HYPR_THEMES_PATH/$THEME_NAME"
else
	echo "Theme '$THEME_NAME' does not exist"
	exit 1
fi

rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

cp -rL --no-preserve=mode "$THEME_PATH/"* "$NEXT_THEME_PATH/" 2>/dev/null

hypr-theme-set-templates

OLD_THEME_PATH="$HOME/.config/hypr-theme/current/old-theme"
rm -rf "$OLD_THEME_PATH"
mv "$CURRENT_THEME_PATH" "$OLD_THEME_PATH" 2>/dev/null || true
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"
rm -rf "$OLD_THEME_PATH"

echo "$THEME_NAME" >"$HOME/.config/hypr-theme/current/theme.name"

QUICKSHELL_BAR_THEME_COLORS="$CURRENT_THEME_PATH/quickshell-bar-colors.json"
if [[ -f "$QUICKSHELL_BAR_THEME_COLORS" ]]; then
	touch "$QUICKSHELL_BAR_THEME_COLORS"
fi

hypr-theme-bg-next

hypr-restart-hyprctl

makoctl reload 2>/dev/null || true

BTOP_CONF="$HOME/.config/btop/btop.conf"
BTOP_THEME="$CURRENT_THEME_PATH/btop.theme"
if [[ -f "$BTOP_CONF" && -f "$BTOP_THEME" ]]; then
	sed -i "s|^color_theme = .*|color_theme = \"$BTOP_THEME\"|" "$BTOP_CONF"
	sed -i 's|^theme_background = .*|theme_background = False|' "$BTOP_CONF"
fi

hypr-theme-set-gnome

notify-send "Theme changed" "$THEME_NAME" -t 2000
