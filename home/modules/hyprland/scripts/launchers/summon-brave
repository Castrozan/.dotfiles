#!/usr/bin/env bash
set -Eeuo pipefail

readonly BRAVE_WINDOW_CLASS="brave-browser"

main() {
	local current_workspace_id window_json
	current_workspace_id=$(hyprctl activeworkspace -j | jq -r '.id')
	window_json=$(_find_window_by_class "$BRAVE_WINDOW_CLASS")

	if [[ -z "$window_json" || "$window_json" == "null" ]]; then
		exec brave
	fi

	local address source_workspace_id
	address=$(echo "$window_json" | jq -r '.address')
	source_workspace_id=$(echo "$window_json" | jq -r '.workspace')

	if [[ "$source_workspace_id" == "$current_workspace_id" ]]; then
		hyprctl dispatch focuswindow "address:$address"
		return
	fi

	hypr-detach-from-group-and-move-to-workspace follow "$current_workspace_id" "$address"
}

_find_window_by_class() {
	hyprctl clients -j | jq -r --arg class "$1" '
    [.[] | select(.class == $class)] | first // empty |
    {address, workspace: .workspace.id}
  '
}

main
