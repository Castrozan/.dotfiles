#!/usr/bin/env bash
set -Eeuo pipefail

readonly FUZZEL_SETTLE_DELAY=0.15

main() {
	if _is_fuzzel_running; then
		pkill -x fuzzel
		exit 0
	fi

	hypr-ensure-workspace-tiled
	hypr-fuzzel || true
	sleep "$FUZZEL_SETTLE_DELAY"
	hypr-ensure-workspace-grouped
}

_is_fuzzel_running() {
	pgrep -x fuzzel >/dev/null
}

main "$@"
