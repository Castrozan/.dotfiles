#!/usr/bin/env bash
set -Eeuo pipefail

readonly MODE="${1:?usage: hypr-detach-from-group-and-move-to-workspace <silent|follow> <workspace> [window-address]}"
readonly TARGET_WORKSPACE="${2:?usage: hypr-detach-from-group-and-move-to-workspace <silent|follow> <workspace> [window-address]}"
readonly WINDOW_ADDRESS="${3:-}"

_detach_move_merge_into_destination_group_and_maximize() {
	local cmds=""

	if [[ -n "$WINDOW_ADDRESS" ]]; then
		cmds+="dispatch focuswindow address:$WINDOW_ADDRESS; "
	fi

	cmds+="dispatch moveoutofgroup"
	cmds+="; dispatch movetoworkspace $TARGET_WORKSPACE"
	cmds+="; dispatch moveintogroup l"
	cmds+="; dispatch moveintogroup r"
	cmds+="; dispatch moveintogroup u"
	cmds+="; dispatch moveintogroup d"
	cmds+="; dispatch fullscreen 1 set"

	if [[ "$MODE" == "silent" ]]; then
		cmds+="; dispatch workspace previous"
		cmds+="; dispatch fullscreenstate 1 0"
	fi

	hyprctl --batch "$cmds"
}

main() {
	_detach_move_merge_into_destination_group_and_maximize
}

main
