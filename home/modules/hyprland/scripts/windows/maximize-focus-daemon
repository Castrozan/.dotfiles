#!/usr/bin/env bash
set -Eeuo pipefail

readonly HYPRLAND_EVENT_SOCKET="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
readonly RECONNECT_INITIAL_DELAY_SECONDS=1
readonly RECONNECT_MAX_DELAY_SECONDS=30
readonly OPENED_WINDOW_WORKSPACE_LOOKUP_ATTEMPTS=5
readonly OPENED_WINDOW_WORKSPACE_LOOKUP_DELAY_SECONDS=0.03

maximized_workspaces=()
previous_focused_address=""
current_focused_address=""

_get_active_window_fullscreen_state() {
	hyprctl activewindow -j 2>/dev/null | jq -r '.fullscreen // 0'
}

_get_workspace_has_fullscreen_window() {
	local workspace_id="$1"
	hyprctl workspaces -j 2>/dev/null | jq -r --arg ws "$workspace_id" '.[] | select(.id == ($ws | tonumber)) | .hasfullscreen'
}

_get_active_workspace_id() {
	hyprctl activewindow -j 2>/dev/null | jq -r '.workspace.id // empty'
}

_get_window_workspace_id_by_address() {
	local window_address="$1"
	hyprctl clients -j 2>/dev/null | jq -r --arg window_address "$window_address" '.[] | select(.address == $window_address) | .workspace.id // empty' | head -n 1
}

_get_opened_window_workspace_id() {
	local window_address="$1"
	local attempt_number=1

	while [[ "$attempt_number" -le "$OPENED_WINDOW_WORKSPACE_LOOKUP_ATTEMPTS" ]]; do
		local window_workspace_id
		window_workspace_id=$(_get_window_workspace_id_by_address "$window_address")
		if [[ -n "$window_workspace_id" ]]; then
			printf '%s\n' "$window_workspace_id"
			return 0
		fi

		sleep "$OPENED_WINDOW_WORKSPACE_LOOKUP_DELAY_SECONDS"
		attempt_number=$((attempt_number + 1))
	done

	return 1
}

_is_workspace_tracked_as_maximized() {
	local workspace_id="$1"
	for tracked in "${maximized_workspaces[@]}"; do
		[[ "$tracked" == "$workspace_id" ]] && return 0
	done
	return 1
}

_add_workspace_to_maximized_tracking() {
	local workspace_id="$1"
	if ! _is_workspace_tracked_as_maximized "$workspace_id"; then
		maximized_workspaces+=("$workspace_id")
	fi
}

_remove_workspace_from_maximized_tracking() {
	local workspace_id="$1"
	local filtered_workspaces=()
	for tracked in "${maximized_workspaces[@]}"; do
		[[ "$tracked" != "$workspace_id" ]] && filtered_workspaces+=("$tracked")
	done
	maximized_workspaces=("${filtered_workspaces[@]}")
}

readonly OFFSCREEN_POSITION="-9999 -9999"

_get_focused_window_properties() {
	local focused_address="$1"
	hyprctl clients -j 2>/dev/null | jq -r \
		--arg focused "$focused_address" \
		'(map(select(.address == $focused)) | first) // empty | "\(.floating)\t\(.workspace.id)"'
}

_get_floating_window_addresses_on_workspace() {
	local workspace_id="$1"
	local exclude_address="$2"
	hyprctl clients -j 2>/dev/null | jq -r \
		--arg ws "$workspace_id" \
		--arg exclude "$exclude_address" \
		'.[] | select(
			.workspace.id == ($ws | tonumber) and
			.floating == true and
			.pinned == false and
			.address != $exclude
		) | .address'
}

_move_floating_windows_offscreen() {
	local focused_address="$1"
	local focused_properties
	focused_properties=$(_get_focused_window_properties "$focused_address")
	[[ -z "$focused_properties" ]] && return

	local is_floating workspace_id
	IFS=$'\t' read -r is_floating workspace_id <<<"$focused_properties"
	[[ "$is_floating" == "true" ]] && return

	local floating_addresses
	floating_addresses=$(_get_floating_window_addresses_on_workspace "$workspace_id" "$focused_address")
	[[ -z "$floating_addresses" ]] && return

	while IFS= read -r address; do
		hyprctl dispatch movewindowpixel "exact $OFFSCREEN_POSITION,address:$address" 2>/dev/null
	done <<<"$floating_addresses"
}

_restore_floating_window_to_center() {
	local window_address="$1"
	local is_floating
	is_floating=$(hyprctl clients -j 2>/dev/null | jq -r \
		--arg addr "$window_address" \
		'(map(select(.address == $addr)) | first) // empty | .floating')
	[[ "$is_floating" != "true" ]] && return

	hyprctl dispatch centerwindow "address:$window_address" 2>/dev/null
}

_handle_active_window_changed_event() {
	local window_address="0x$1"
	if [[ "$window_address" != "$current_focused_address" ]]; then
		previous_focused_address="$current_focused_address"
		current_focused_address="$window_address"
	fi
	_restore_floating_window_to_center "$window_address"
	_move_floating_windows_offscreen "$window_address"
}

_handle_fullscreen_event() {
	local fullscreen_state="$1"
	if [[ "$fullscreen_state" == "1" ]]; then
		local workspace_id
		workspace_id=$(_get_active_workspace_id)
		[[ -n "$workspace_id" ]] && _add_workspace_to_maximized_tracking "$workspace_id"
	fi
}

_remaximize_active_workspace_if_needed() {
	local workspace_id
	workspace_id=$(_get_active_workspace_id)
	[[ -z "$workspace_id" ]] && return

	_is_workspace_tracked_as_maximized "$workspace_id" || return

	local current_fullscreen_state
	current_fullscreen_state=$(_get_active_window_fullscreen_state)
	if [[ "$current_fullscreen_state" != "1" ]]; then
		local tiled_window_count
		tiled_window_count=$(hyprctl clients -j 2>/dev/null | jq --arg ws "$workspace_id" '[.[] | select(.workspace.id == ($ws | tonumber) and .floating == false)] | length')
		if [[ "$tiled_window_count" -gt 0 ]]; then
			hyprctl dispatch fullscreen 1 set
		else
			_remove_workspace_from_maximized_tracking "$workspace_id"
		fi
	fi
}

_handle_close_window_event() {
	local closed_address="0x$1"

	if [[ "$closed_address" == "$current_focused_address" && -n "$previous_focused_address" ]]; then
		hyprctl dispatch focuswindow "address:$previous_focused_address"
		current_focused_address="$previous_focused_address"
		previous_focused_address=""
	elif [[ "$closed_address" == "$previous_focused_address" ]]; then
		previous_focused_address=""
	fi

	sleep 0.03
	_remaximize_active_workspace_if_needed
}

_handle_workspace_changed_event() {
	sleep 0.05
	_remaximize_active_workspace_if_needed
}

_handle_open_window_event() {
	local event_data="$1"
	local window_address="0x${event_data%%,*}"
	local workspace_id

	workspace_id=$(_get_opened_window_workspace_id "$window_address") || return
	_is_workspace_tracked_as_maximized "$workspace_id" || return

	local active_workspace_id
	active_workspace_id=$(_get_active_workspace_id)
	[[ "$workspace_id" != "$active_workspace_id" ]] && return

	hyprctl --batch "dispatch focuswindow address:$window_address ; dispatch fullscreen 1 set"
}

_handle_hyprland_event() {
	local event="$1"
	local data="$2"

	case "$event" in
	activewindowv2) _handle_active_window_changed_event "$data" ;;
	fullscreen) _handle_fullscreen_event "$data" ;;
	closewindow) _handle_close_window_event "$data" ;;
	openwindow) _handle_open_window_event "$data" ;;
	workspace) _handle_workspace_changed_event "$data" ;;
	esac
}

_initialize_maximized_workspace_tracking() {
	maximized_workspaces=()
	while IFS= read -r workspace_id; do
		if [[ "$(_get_workspace_has_fullscreen_window "$workspace_id")" == "true" ]]; then
			_add_workspace_to_maximized_tracking "$workspace_id"
		fi
	done < <(hyprctl workspaces -j | jq -r '.[].id')
}

_initialize_focused_window_tracking() {
	current_focused_address=$(hyprctl activewindow -j 2>/dev/null | jq -r '.address // empty')
	previous_focused_address=""
}

_read_and_dispatch_hyprland_events() {
	while IFS= read -r line; do
		local event="${line%%>>*}"
		local data="${line#*>>}"
		_handle_hyprland_event "$event" "$data"
	done < <(nc -U "$HYPRLAND_EVENT_SOCKET")
}

_wait_for_hyprland_socket() {
	local delay_seconds="$1"
	while [[ ! -S "$HYPRLAND_EVENT_SOCKET" ]]; do
		sleep "$delay_seconds"
	done
}

_connect_and_process_events_with_reconnect() {
	local reconnect_delay_seconds="$RECONNECT_INITIAL_DELAY_SECONDS"

	while true; do
		_initialize_maximized_workspace_tracking
		_initialize_focused_window_tracking
		_read_and_dispatch_hyprland_events

		_wait_for_hyprland_socket "$reconnect_delay_seconds"

		if [[ "$reconnect_delay_seconds" -lt "$RECONNECT_MAX_DELAY_SECONDS" ]]; then
			reconnect_delay_seconds=$((reconnect_delay_seconds * 2))
			if [[ "$reconnect_delay_seconds" -gt "$RECONNECT_MAX_DELAY_SECONDS" ]]; then
				reconnect_delay_seconds="$RECONNECT_MAX_DELAY_SECONDS"
			fi
		fi
	done
}

main() {
	_connect_and_process_events_with_reconnect
}

main
