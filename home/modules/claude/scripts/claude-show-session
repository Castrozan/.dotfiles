#!/usr/bin/env bash
set -eu

current_directory_path=$(pwd)
encoded_project_directory_name=$(printf '%s' "$current_directory_path" | sed 's|[/.]|-|g')
project_directory="$HOME/.claude/projects/$encoded_project_directory_name"

if [ ! -d "$project_directory" ]; then
	printf 'No claude project directory found at %s\n' "$project_directory" >&2
	exit 1
fi

latest_session_jsonl=$(find "$project_directory" -maxdepth 1 -type f -name '*.jsonl' -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -n 1 | cut -d' ' -f2-)

if [ -z "$latest_session_jsonl" ]; then
	printf 'No session jsonl found in %s\n' "$project_directory" >&2
	exit 1
fi

printf '# Session: %s\n# File: %s\n\n' "$(basename "$latest_session_jsonl" .jsonl)" "$latest_session_jsonl"

jq -r '
  select(.message.role) |
  .message.role as $role |
  (
    if (.message.content | type) == "string" then
      .message.content
    else
      (.message.content // []) | map(
        if .type == "text" then .text
        elif .type == "thinking" then "[thinking]\n" + (.thinking // "")
        elif .type == "tool_use" then "[tool_use: " + (.name // "?") + "]\n" + ((.input // {}) | tostring)
        elif .type == "tool_result" then "[tool_result]\n" + (
          if (.content | type) == "string" then .content
          elif (.content | type) == "array" then (.content | map(select(.type == "text") | .text) | join("\n"))
          else "" end
        )
        else "" end
      ) | join("\n")
    end
  ) as $rendered_text |
  "================================================================================\n[\($role)]\n\($rendered_text)\n"
' "$latest_session_jsonl"
