import argparse
import datetime
import json
import os
import shlex
import signal
import subprocess
import sys
import tempfile
import time
import uuid
from pathlib import Path

DEFAULT_HEARTBEAT_INTERVAL = "3,33 * * * *"
DEFAULT_MODEL = "opus"
CLAUDE_INPUT_PROMPT_INDICATOR = "❯"
MAX_WAIT_ATTEMPTS_FOR_CLAUDE_PROMPT = 30
PM_WINDOW_NAME = "pm"
CLAUDE_PROCESS_COMMAND_NAMES = frozenset({"claude", "node"})
CLAUDE_PROJECTS_TRANSCRIPTS_DIRECTORY = Path.home() / ".claude" / "projects"
GRACEFUL_SHUTDOWN_WAIT_SECONDS = 60


def install_exit_signal_handlers() -> None:
    def terminate_cleanly(_signal_number: int, _frame_object) -> None:
        sys.exit(0)

    for signal_number in (signal.SIGTERM, signal.SIGHUP, signal.SIGINT):
        signal.signal(signal_number, terminate_cleanly)


def is_within_active_hours(
    active_hours_start: int | None, active_hours_end: int | None
) -> bool:
    if active_hours_start is None:
        return True
    current_hour = time.localtime().tm_hour
    if active_hours_start <= active_hours_end:
        return active_hours_start <= current_hour < active_hours_end
    return current_hour >= active_hours_start or current_hour < active_hours_end


def seconds_until_active_hours_start(active_hours_start: int) -> int:
    now = datetime.datetime.now()
    target = now.replace(hour=active_hours_start, minute=0, second=0, microsecond=0)
    if target <= now:
        target += datetime.timedelta(days=1)
    return int((target - now).total_seconds())


def sleep_until_active_hours(active_hours_start: int, agent_name: str) -> None:
    sleep_seconds = seconds_until_active_hours_start(active_hours_start)
    print(
        f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] "
        f"Agent {agent_name} outside active hours. "
        f"Sleeping {sleep_seconds}s until {active_hours_start:02d}:00...",
        flush=True,
    )
    time.sleep(sleep_seconds)


def terminate_agent_gracefully(tmux_socket: str, session_name: str) -> None:
    target = f"{session_name}:{PM_WINDOW_NAME}"

    if check_claude_running_in_window(tmux_socket, target):
        if wait_for_claude_input_prompt(tmux_socket, target):
            send_keys_to_tmux_pane(tmux_socket, target, "/exit")
            for _ in range(GRACEFUL_SHUTDOWN_WAIT_SECONDS):
                time.sleep(1)
                if not check_claude_running_in_window(tmux_socket, target):
                    break

    run_tmux_command(tmux_socket, "kill-session", "-t", session_name)
    print(
        f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] "
        f"Agent {session_name} shut down for end of active hours.",
        flush=True,
    )


def find_tmux_socket() -> str | None:
    tmux_tmpdir = os.environ.get("TMUX_TMPDIR")
    uid = os.getuid()
    candidate_directories = []
    if tmux_tmpdir:
        candidate_directories.append(Path(tmux_tmpdir))
    candidate_directories.extend(
        [
            Path(f"/run/user/{uid}/tmux-{uid}"),
            Path(f"/tmp/tmux-{uid}"),
        ]
    )
    for directory in candidate_directories:
        if directory.exists():
            for socket_file in directory.glob("default"):
                if socket_file.is_socket():
                    return str(socket_file)
    return None


def run_tmux_command(tmux_socket: str, *arguments: str) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["tmux", "-S", tmux_socket, *arguments],
        capture_output=True,
        text=True,
    )


def validate_project_directory(project_directory: Path) -> None:
    if not project_directory.is_dir():
        print(
            f"Error: project directory not found: {project_directory}",
            file=sys.stderr,
        )
        sys.exit(1)

    claude_md = project_directory / "CLAUDE.md"
    if not claude_md.is_file():
        print(
            f"Error: no CLAUDE.md found in {project_directory}"
            " - the agent needs instructions",
            file=sys.stderr,
        )
        sys.exit(1)


def ensure_pm_workspace_exists(
    project_directory: Path,
) -> Path:
    pm_directory = project_directory / ".pm"
    pm_directory.mkdir(exist_ok=True)
    heartbeat_file = pm_directory / "HEARTBEAT.md"
    if not heartbeat_file.exists():
        heartbeat_file.write_text("# Heartbeat\n\nNo active work.\n")
        print(f"Created {heartbeat_file}")
    gitignore = project_directory / ".gitignore"
    if gitignore.exists():
        content = gitignore.read_text()
        if ".pm/" not in content:
            gitignore.write_text(content.rstrip("\n") + "\n.pm/\n")
            print(f"Added .pm/ to {gitignore}")
    return pm_directory


def load_or_create_agent_config(pm_directory: Path, agent_name: str) -> dict:
    config_file = pm_directory / "agent.json"
    if config_file.exists():
        try:
            return json.loads(config_file.read_text())
        except json.JSONDecodeError:
            print(
                f"Warning: malformed {config_file}, using defaults",
                file=sys.stderr,
            )
    config = {
        "model": DEFAULT_MODEL,
        "heartbeat": DEFAULT_HEARTBEAT_INTERVAL,
        "name": agent_name,
    }
    config_file.write_text(json.dumps(config, indent=2) + "\n")
    print(f"Created {config_file}")
    return config


def check_tmux_session_exists(tmux_socket: str, session_name: str) -> bool:
    result = run_tmux_command(tmux_socket, "has-session", "-t", session_name)
    return result.returncode == 0


def check_tmux_window_exists(
    tmux_socket: str, session_name: str, window_name: str
) -> bool:
    result = run_tmux_command(
        tmux_socket,
        "list-windows",
        "-t",
        session_name,
        "-F",
        "#{window_name}",
    )
    if result.returncode != 0:
        return False
    windows = result.stdout.strip().splitlines()
    return window_name in windows


def get_pane_current_command(tmux_socket: str, target: str) -> str | None:
    result = run_tmux_command(
        tmux_socket,
        "list-panes",
        "-t",
        target,
        "-F",
        "#{pane_current_command}",
    )
    if result.returncode != 0:
        return None
    lines = result.stdout.strip().splitlines()
    return lines[0] if lines else None


def check_claude_running_in_window(tmux_socket: str, target: str) -> bool:
    current_command = get_pane_current_command(tmux_socket, target)
    if not current_command:
        return False
    return current_command.lower() in CLAUDE_PROCESS_COMMAND_NAMES


def create_tmux_session_with_pm_window(
    tmux_socket: str,
    session_name: str,
    working_directory: Path,
) -> None:
    result = run_tmux_command(
        tmux_socket,
        "new-session",
        "-d",
        "-s",
        session_name,
        "-n",
        PM_WINDOW_NAME,
        "-c",
        str(working_directory),
    )
    if result.returncode != 0:
        print(
            f"Error creating tmux session: {result.stderr.strip()}",
            file=sys.stderr,
        )
        sys.exit(1)


def create_pm_window_in_existing_session(
    tmux_socket: str,
    session_name: str,
    working_directory: Path,
) -> None:
    result = run_tmux_command(
        tmux_socket,
        "new-window",
        "-t",
        session_name,
        "-n",
        PM_WINDOW_NAME,
        "-c",
        str(working_directory),
    )
    if result.returncode != 0:
        print(
            f"Error creating window: {result.stderr.strip()}",
            file=sys.stderr,
        )
        sys.exit(1)


def ensure_pm_window(
    tmux_socket: str,
    session_name: str,
    working_directory: Path,
) -> tuple[str, bool]:
    target = f"{session_name}:{PM_WINDOW_NAME}"

    if not check_tmux_session_exists(tmux_socket, session_name):
        create_tmux_session_with_pm_window(tmux_socket, session_name, working_directory)
        print(f"  Created session '{session_name}' with pm window")
        return target, False

    if check_tmux_window_exists(tmux_socket, session_name, PM_WINDOW_NAME):
        if check_claude_running_in_window(tmux_socket, target):
            print(f"  PM agent already running in {target}")
            print(f"  Attach: tmux select-window -t {target}")
            return target, True
        print(f"  Reusing existing pm window in '{session_name}'")
        return target, False

    create_pm_window_in_existing_session(tmux_socket, session_name, working_directory)
    print(f"  Created pm window in session '{session_name}'")
    return target, False


def send_keys_to_tmux_pane(tmux_socket: str, target: str, keys: str) -> None:
    result = run_tmux_command(
        tmux_socket,
        "list-panes",
        "-t",
        target,
        "-F",
        "#{pane_index}",
    )
    lines = result.stdout.strip().splitlines() if result.returncode == 0 else []
    pane_index = lines[0] if lines else "0"
    run_tmux_command(
        tmux_socket,
        "send-keys",
        "-t",
        f"{target}.{pane_index}",
        keys,
        "Enter",
    )


def wait_for_claude_input_prompt(tmux_socket: str, target: str) -> bool:
    for _ in range(MAX_WAIT_ATTEMPTS_FOR_CLAUDE_PROMPT):
        if not check_claude_running_in_window(tmux_socket, target):
            time.sleep(1)
            continue
        result = run_tmux_command(
            tmux_socket,
            "capture-pane",
            "-t",
            target,
            "-p",
            "-S",
            "-10",
        )
        if result.returncode == 0 and CLAUDE_INPUT_PROMPT_INDICATOR in result.stdout:
            return True
        time.sleep(1)
    return False


def build_bootstrap_prompt(heartbeat_interval: str) -> str:
    heartbeat_tick_prompt = (
        "Heartbeat tick. Read .pm/HEARTBEAT.md."
        " If there are pending tasks with elapsed intervals,"
        " work on the highest priority one."
        " If nothing needs attention,"
        " do nothing - do not respond or log."
    )
    return (
        "You are a persistent project agent."
        " Set up your heartbeat loop now:"
        f' use CronCreate with cron: "{heartbeat_interval}",'
        " recurring: true, and this prompt:\n\n"
        f'"{heartbeat_tick_prompt}"\n\n'
        "Then read .pm/HEARTBEAT.md."
        " If it contains only 'No active work',"
        " this is your first session - follow your"
        " onboarding instructions."
        " Otherwise, read your state from disk"
        " and resume operations."
    )


def send_bootstrap_prompt(
    tmux_socket: str, target: str, heartbeat_interval: str
) -> None:
    bootstrap_content = build_bootstrap_prompt(heartbeat_interval)

    with tempfile.NamedTemporaryFile(
        mode="w",
        prefix="project-agent-bootstrap-",
        suffix=".md",
        delete=False,
    ) as f:
        f.write(bootstrap_content)
        bootstrap_file = f.name

    buffer_name = "project-agent-bootstrap"
    try:
        if not wait_for_claude_input_prompt(tmux_socket, target):
            print(
                "Error: claude did not reach input prompt"
                f" within {MAX_WAIT_ATTEMPTS_FOR_CLAUDE_PROMPT}s"
                " - refusing to send bootstrap into shell."
                " Check the pm window for error output.",
                file=sys.stderr,
            )
            return
        load_result = run_tmux_command(
            tmux_socket, "load-buffer", "-b", buffer_name, bootstrap_file
        )
        if load_result.returncode != 0:
            print(
                f"Error: failed to load bootstrap buffer: {load_result.stderr.strip()}",
                file=sys.stderr,
            )
            return
        paste_result = run_tmux_command(
            tmux_socket, "paste-buffer", "-b", buffer_name, "-t", target
        )
        if paste_result.returncode != 0:
            print(
                f"Error: failed to paste bootstrap: {paste_result.stderr.strip()}",
                file=sys.stderr,
            )
            return
        run_tmux_command(tmux_socket, "send-keys", "-t", target, "Enter")
        run_tmux_command(tmux_socket, "delete-buffer", "-b", buffer_name)
    finally:
        os.unlink(bootstrap_file)


def resolve_persistent_session_id(project_directory: Path, agent_name: str) -> str:
    session_file = project_directory / ".pm" / "session-id"
    if session_file.exists():
        stored_id = session_file.read_text().strip()
        if stored_id:
            return stored_id
    session_seed = f"{agent_name}-project-manager-agent"
    persistent_id = str(uuid.uuid5(uuid.NAMESPACE_DNS, session_seed))
    session_file.write_text(persistent_id + "\n")
    return persistent_id


def encode_project_path_for_claude_transcripts(project_directory: Path) -> str:
    return str(project_directory).replace("/", "-").replace(".", "-")


def find_existing_transcript_for_session(
    project_directory: Path, session_id: str
) -> Path | None:
    encoded_path = encode_project_path_for_claude_transcripts(project_directory)
    transcript_file = (
        CLAUDE_PROJECTS_TRANSCRIPTS_DIRECTORY / encoded_path / f"{session_id}.jsonl"
    )
    return transcript_file if transcript_file.is_file() else None


def resolve_project_agent_instructions_file() -> str | None:
    instructions_path = os.environ.get("PROJECT_AGENT_INSTRUCTIONS")
    if not instructions_path:
        return None
    if not Path(instructions_path).is_file():
        print(
            f"Warning: PROJECT_AGENT_INSTRUCTIONS set"
            f" but file not found: {instructions_path}",
            file=sys.stderr,
        )
        return None
    return instructions_path


def build_claude_launch_command(
    model: str,
    agent_name: str,
    session_id: str,
    resume_existing_session: bool,
    instructions_file: str | None = None,
) -> str:
    parts = ["claude"]
    parts.append(f"--model {shlex.quote(model)}")
    parts.append(f"--name {shlex.quote(agent_name)}")
    parts.append("--dangerously-skip-permissions")
    if resume_existing_session:
        parts.append(f"--resume {shlex.quote(session_id)}")
    else:
        parts.append(f"--session-id {shlex.quote(session_id)}")
    if instructions_file:
        parts.append(f"--append-system-prompt-file {shlex.quote(instructions_file)}")
    return " ".join(parts)


def parse_arguments() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="launch-project-agent",
        description=(
            "Launch a persistent project agent"
            " (Claude Code + heartbeat loop)"
            " as a pm window in the project's tmux session."
        ),
        epilog=(
            "The agent runs onboarding on first launch"
            " (reads project, asks questions, sets up state),"
            " then works autonomously via heartbeat."
            " State lives in .pm/ inside the project."
            " Attach with: tmux attach -t <project-name>"
        ),
    )
    parser.add_argument(
        "project_directory",
        type=Path,
        help="Path to the project. Must contain a CLAUDE.md.",
    )
    parser.add_argument(
        "--model",
        default=None,
        help="Claude model (overrides .pm/agent.json)",
    )
    parser.add_argument(
        "--name",
        dest="agent_name",
        default=None,
        help="Agent/session name (overrides .pm/agent.json)",
    )
    parser.add_argument(
        "--heartbeat",
        default=None,
        help="Heartbeat cron (overrides .pm/agent.json)",
    )
    parser.add_argument(
        "--no-bootstrap",
        action="store_true",
        help="Skip sending the bootstrap prompt",
    )
    parser.add_argument(
        "--keepalive",
        action="store_true",
        help="Stay alive while tmux session exists (for systemd)",
    )
    parser.add_argument(
        "--active-hours-start",
        type=int,
        default=None,
        dest="active_hours_start",
        help="Hour (0-23) when agent becomes active",
    )
    parser.add_argument(
        "--active-hours-end",
        type=int,
        default=None,
        dest="active_hours_end",
        help="Hour (0-23) when agent goes dormant",
    )
    return parser.parse_args()


def main() -> None:
    args = parse_arguments()

    if args.active_hours_start is not None:
        install_exit_signal_handlers()

    project_directory = args.project_directory.resolve()
    validate_project_directory(project_directory)
    pm_directory = ensure_pm_workspace_exists(project_directory)

    default_name = project_directory.name
    agent_config = load_or_create_agent_config(pm_directory, default_name)

    agent_name = args.agent_name or agent_config.get("name", default_name)
    model = args.model or agent_config.get("model", DEFAULT_MODEL)
    heartbeat = args.heartbeat or agent_config.get(
        "heartbeat", DEFAULT_HEARTBEAT_INTERVAL
    )

    tmux_socket = find_tmux_socket()
    if not tmux_socket:
        print("Error: no tmux socket found", file=sys.stderr)
        sys.exit(1)

    if not is_within_active_hours(args.active_hours_start, args.active_hours_end):
        sleep_until_active_hours(args.active_hours_start, agent_name)

    session_name = agent_name
    target, claude_already_running = ensure_pm_window(
        tmux_socket, session_name, project_directory
    )

    persistent_session_id = resolve_persistent_session_id(project_directory, agent_name)
    existing_transcript = find_existing_transcript_for_session(
        project_directory, persistent_session_id
    )
    resume_existing_session = existing_transcript is not None

    if claude_already_running:
        session_mode = "already-running"
    else:
        instructions_file = resolve_project_agent_instructions_file()
        claude_command = build_claude_launch_command(
            model,
            agent_name,
            persistent_session_id,
            resume_existing_session,
            instructions_file,
        )
        send_keys_to_tmux_pane(tmux_socket, target, claude_command)
        session_mode = "resume" if resume_existing_session else "new"
        if not args.no_bootstrap and not resume_existing_session:
            send_bootstrap_prompt(tmux_socket, target, heartbeat)

    print(f"Launched project agent '{agent_name}'")
    print(f"  Window: {target}")
    print(f"  Claude session: {persistent_session_id} ({session_mode})")
    print(f"  Model: {model}")
    print(f"  Heartbeat: {heartbeat}")
    print(f"  Attach: tmux select-window -t {target}")

    if args.keepalive:
        keepalive_while_tmux_session_exists(
            tmux_socket,
            agent_name,
            args.active_hours_start,
            args.active_hours_end,
        )


def keepalive_while_tmux_session_exists(
    tmux_socket: str,
    session_name: str,
    active_hours_start: int | None = None,
    active_hours_end: int | None = None,
) -> None:
    while check_tmux_session_exists(tmux_socket, session_name):
        if not is_within_active_hours(active_hours_start, active_hours_end):
            terminate_agent_gracefully(tmux_socket, session_name)
            return
        time.sleep(10)


if __name__ == "__main__":
    main()
