  "github.copilot.enable": {
    "*": false,
    "plaintext": true,
    "markdown": false,
    "scminput": true
  },
  "[shellscript]": {
    "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode"
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "redhat.telemetry.enabled": false,
  "accessibility.voice.keywordActivation": "chatInView",
  "workbench.startupEditor": "none",
  "chat.agent.enabled": true,
  "git.blame.editorDecoration.enabled": false,
  "git.enableSmartCommit": true,
  "python.analysis.typeCheckingMode": "basic",
  "git.repositoryScanMaxDepth": 0,
  "git.scanRepositories": [],
  "search.exclude": {
    "**/.worktrees": true
  },
  "files.exclude": {
    "**/.worktrees": true
  },
  "git.autoRepositoryDetection": "openEditors",
  "git.confirmSync": false,
  "git.replaceTagsWhenPull": true,
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
    "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.ui": "default",
    "*.qrc": "qt-core.qrcEditor"
  },
  "workbench.preferredLightColorTheme": "GitHub Dark Default",
  "chat.mcp.gallery.enabled": true,
  "chat.useAgentsMdFile": true,
  "chat.useClaudeMdFile": true,
  "chat.promptFilesLocations": {
    ".github/prompts": true,
    ".copilot/prompts": true
  },
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    ".copilot/instructions": true,
    "~/.claude/rules": false,
    "~/.config/betha/instructions": true
  },
  "chat.mcp.access": "all",
  "chat.mcp.serverSampling": {},
  "chat.agent.maxRequests": 9999999999,
  "chat.viewSessions.orientation": "stacked",
  "chat.plugins.marketplaces": [
    "git@gitlab.services.betha.cloud:betha-ai/betha.ai-marketplace.git"
  ],
  "chat.tools.terminal.autoApprove": {
    "/^uname -r$/": {
      "approve": true,
      "matchCommandLine": true
    }
  },
  "chat.tools.autoApprove": true
}
