  "editor.rulers": [80, 120],
  "nix.serverPath": "nixd",
  "nix.enableLanguageServer": true,
  "nix.hiddenLanguageServerErrors": ["textDocument/definition"],
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": ["nixfmt"]
      }
    }
  },
