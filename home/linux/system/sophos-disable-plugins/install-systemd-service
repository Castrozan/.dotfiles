#!/usr/bin/env bash

set -Eeuo pipefail

INSTALLER_SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly INSTALLER_SCRIPT_DIRECTORY
readonly STOP_SCRIPT_SOURCE_PATH="$INSTALLER_SCRIPT_DIRECTORY/stop-sophos-noisy-plugins"
readonly STOP_SCRIPT_INSTALLED_PATH=/usr/local/sbin/sophos-disable-noisy-plugins-stop
readonly SYSTEMD_UNIT_INSTALLED_PATH=/etc/systemd/system/sophos-disable-noisy-plugins.service
readonly SYSTEMD_UNIT_NAME=sophos-disable-noisy-plugins.service

main() {
	_install_stop_script_to_system_path
	_write_systemd_unit_file
	_reload_systemd_and_activate_unit
	echo "$SYSTEMD_UNIT_NAME installed and active"
}

_install_stop_script_to_system_path() {
	sudo install -m 0755 "$STOP_SCRIPT_SOURCE_PATH" "$STOP_SCRIPT_INSTALLED_PATH"
}

_write_systemd_unit_file() {
	sudo tee "$SYSTEMD_UNIT_INSTALLED_PATH" >/dev/null <<UNIT
[Unit]
Description=Stop noisy Sophos plugins (av, runtimedetections) after sophos-spl starts
Requires=sophos-spl.service
After=sophos-spl.service
PartOf=sophos-spl.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=$STOP_SCRIPT_INSTALLED_PATH

[Install]
WantedBy=multi-user.target
UNIT
}

_reload_systemd_and_activate_unit() {
	sudo systemctl daemon-reload
	sudo systemctl enable --now "$SYSTEMD_UNIT_NAME"
}

main "$@"
